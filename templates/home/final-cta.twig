<section class="nc-section" aria-label="Chamada final" data-aos="fade-up" data-aos-delay="0">
  {% set cta_section = homeContent.sections.cta|default({}) %}
  {% set cta_actions = homeContent.ctaActions|default([]) %}

  {% include 'components/section-header.twig' with {
    kicker: cta_section.kicker|default('Acao'),
    title: cta_section.title|default('Pronto para resolver problemas reais com tecnologia certa?'),
    lead: cta_section.lead|default('Venha conhecer o CEDE e encontrar respostas para suas indagações espirituais.')
  } %}
  {% if cta_section.address is defined and cta_section.address %}
    <p class="nc-section-lead" data-aos="fade-up" data-aos-delay="120">
      {% if cta_section.addressMapUrl is defined and cta_section.addressMapUrl %}
        <a href="{{ cta_section.addressMapUrl }}" target="_blank" rel="noopener noreferrer">{{ cta_section.address }}</a>
      {% else %}
        {{ cta_section.address }}
      {% endif %}
    </p>
  {% endif %}
  <div class="nc-actions" data-aos="fade-up" data-aos-delay="{{ cta_section.actionsDelay|default(160) }}">
    {% for action in cta_actions %}
      <a
        class="{{ action.class }}"
        href="{{ action.href }}"
        {% if action.loadingOnClick|default(false) %}data-loading-on-click{% endif %}
        {% if action.ariaDisabled|default(false) %}aria-disabled="true" tabindex="-1"{% endif %}
      >{{ action.ariaDisabled|default(false) ? action.disabledLabel|default('Em breve') : action.label }}</a>
    {% endfor %}
  </div>
</section>
