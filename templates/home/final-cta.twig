<section class="nc-section nc-home-final-cta" aria-label="Chamada final" data-aos="fade-up" data-aos-delay="0">
  {% set cta_section = homeContent.sections.cta|default({}) %}
  {% set cta_actions = homeContent.ctaActions|default([]) %}

  {% include 'components/section-header.twig' with {
    kicker: cta_section.kicker|default('Ação'),
    title: cta_section.title|default('Pronto para resolver problemas reais com tecnologia certa?'),
    lead: cta_section.lead|default('Fale com a NatalCode e transforme seu objetivo comercial em entrega digital.')
  } %}
  <div class="nc-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="{{ cta_section.actionsDelay|default(160) }}">
    {% for action in cta_actions %}
      {% set action_href = action.href|default('#') %}
      <a
        class="{{ action.class|default('nc-btn nc-btn-primary') }}"
        href="{{ action_href }}"
        {% if action.loadingOnClick|default(false) %}data-loading-on-click{% endif %}
        {% if action.ariaDisabled|default(false) %}aria-disabled="true" tabindex="-1"{% endif %}
      >{{ action.ariaDisabled|default(false) ? action.disabledLabel|default('Em breve') : action.label|default('Saiba mais') }}</a>
    {% endfor %}
    {% if app_whatsapp_number|default('') %}
      <a
        class="nc-btn nc-btn-secondary"
        href="https://wa.me/{{ app_whatsapp_number }}?text={{ app_whatsapp_message|default('')|url_encode }}"
        target="_blank"
        rel="noopener noreferrer"
      >Falar no WhatsApp</a>
    {% endif %}
  </div>
</section>
