<section id="quem-somos" class="nc-section" aria-label="Quem Somos" data-aos="fade-up" data-aos-delay="0">
  {% set social_proof = homeContent.sections.socialProof|default({}) %}

  <div class="nc-about-header">
    {% include 'components/section-header.twig' with {
      kicker: social_proof.kicker|default('Quem Somos'),
      title: social_proof.title|default('Centro de Estudos da Doutrina Espírita - CEDE'),
      lead: social_proof.lead|default('O Centro de Estudos da Doutrina Espírita - CEDE é uma associação civil sem fins lucrativos voltada ao estudo, à prática e à divulgação da Doutrina Espírita.'),
      lead_secondary: social_proof.leadSecondary|default('')
    } %}
  </div>
</section>
