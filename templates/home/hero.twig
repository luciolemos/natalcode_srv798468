{% set hero = homeContent.sections.hero|default({}) %}
{% set hero_actions = homeContent.heroActions|default([]) %}
{% set hero_metrics = homeContent.heroMetrics|default([]) %}
{% set hero_qr_url = hero.qrUrl|default('') %}
{% set hero_qr_image = hero.qrImage|default('') %}
{% set hero_image_src = hero.imageSrc|default('') %}
{% set hero_default_kicker = hero.kicker|default('Início') %}
{% set hero_default_title = hero.title|default('NatalCode Agência Digital') %}
{% set hero_default_tagline = hero.tagline|default('') %}
{% set hero_default_lead = hero.lead|default('Desenvolvemos sistemas sob medida para melhorar operação, produtividade e resultado. Unimos tecnologia, usabilidade e estratégia para entregar valor de forma prática e contínua.') %}
{% set hero_default_badge = hero.badge|default('') %}
{% set hero_image_alt = hero.imageAlt|default(hero_default_title) %}
{% set hero_media = [] %}
{% for image in hero.images|default([]) %}
  {% if image.src is defined %}
    {% set media_src = image.src is not null ? image.src|trim : '' %}
    {% if media_src != '' %}
      {% set hero_media = hero_media|merge([{
        src: media_src,
        srcset: image.srcset|default(''),
        webpSrcset: image.webpSrcset|default(''),
        avifSrcset: image.avifSrcset|default(''),
        sizes: image.sizes|default('100vw'),
        mobileSrcset: image.mobileSrcset|default(''),
        mobileWebpSrcset: image.mobileWebpSrcset|default(''),
        mobileAvifSrcset: image.mobileAvifSrcset|default(''),
        mobileSizes: image.mobileSizes|default(''),
        kicker: image.kicker|default(hero_default_kicker),
        badge: image.badge|default(hero_default_badge),
        title: image.title|default(hero_default_title),
        tagline: image.tagline|default(hero_default_tagline),
        lead: image.lead|default(hero_default_lead),
        imageAlt: image.imageAlt|default(hero_image_alt)
      }]) %}
    {% endif %}
  {% else %}
    {% set media_src = image is not null ? image|trim : '' %}
    {% if media_src != '' %}
      {% set hero_media = hero_media|merge([{
        src: media_src,
        srcset: '',
        webpSrcset: '',
        avifSrcset: '',
        sizes: '100vw',
        mobileSrcset: '',
        mobileWebpSrcset: '',
        mobileAvifSrcset: '',
        mobileSizes: '',
        kicker: hero_default_kicker,
        badge: hero_default_badge,
        title: hero_default_title,
        tagline: hero_default_tagline,
        lead: hero_default_lead,
        imageAlt: hero_image_alt
      }]) %}
    {% endif %}
  {% endif %}
{% endfor %}
{% if hero_image_src %}
  {% set has_hero_image_src = false %}
  {% for media in hero_media %}
    {% if media.src == hero_image_src %}
      {% set has_hero_image_src = true %}
    {% endif %}
  {% endfor %}
  {% if not has_hero_image_src %}
    {% set hero_media = [{
      src: hero_image_src,
      srcset: '',
      webpSrcset: '',
      avifSrcset: '',
      sizes: '100vw',
      mobileSrcset: '',
      mobileWebpSrcset: '',
      mobileAvifSrcset: '',
      mobileSizes: '',
      kicker: hero_default_kicker,
      badge: hero_default_badge,
      title: hero_default_title,
      tagline: hero_default_tagline,
      lead: hero_default_lead,
      imageAlt: hero_image_alt
    }]|merge(hero_media) %}
  {% endif %}
{% endif %}
{% set hero_primary_media = hero_media|length > 0 ? hero_media[0] : null %}
{% set hero_primary_kicker = hero_primary_media and hero_primary_media.kicker is defined ? hero_primary_media.kicker : hero_default_kicker %}
{% set hero_primary_badge = hero_primary_media and hero_primary_media.badge is defined ? hero_primary_media.badge : hero_default_badge %}
{% set hero_primary_title = hero_primary_media and hero_primary_media.title is defined ? hero_primary_media.title : hero_default_title %}
{% set hero_primary_tagline = hero_primary_media and hero_primary_media.tagline is defined ? hero_primary_media.tagline : hero_default_tagline %}
{% set hero_primary_lead = hero_primary_media and hero_primary_media.lead is defined ? hero_primary_media.lead : hero_default_lead %}
{% set hero_primary_image_alt = hero_primary_media and hero_primary_media.imageAlt is defined ? hero_primary_media.imageAlt : hero_image_alt %}
{% set hero_primary_has_tagline = hero_primary_tagline is not null and hero_primary_tagline|trim != '' %}
{% set hero_panel_enabled = hero.showPanel is defined ? hero.showPanel : true %}
{% set hero_panel_has_content = hero_metrics|length > 0 or (hero_qr_url and hero_qr_image) %}
{% set show_hero_panel = hero_panel_enabled and hero_panel_has_content %}

<section
  class="nc-section nc-home-hero{% if hero_primary_media %} has-background-image{% endif %}"
  aria-label="Hero principal"
  data-aos="fade-up"
  data-aos-delay="0"
  {% if hero_media|length > 1 %}data-hero-media="{{ hero_media|json_encode|e('html_attr') }}" data-hero-interval="{{ hero.imageIntervalMs|default(5500) }}"{% endif %}
>
  {% if hero_primary_media %}
    <div class="nc-home-hero-media" aria-hidden="true">
      <picture data-hero-picture>
        <source data-hero-source-avif-mobile type="image/avif" media="(max-width: 700px)"{% if hero_primary_media.mobileAvifSrcset|default('') %} srcset="{{ hero_primary_media.mobileAvifSrcset|e('html_attr') }}"{% endif %}{% if hero_primary_media.mobileSizes|default('') %} sizes="{{ hero_primary_media.mobileSizes|e('html_attr') }}"{% endif %}>
        <source data-hero-source-webp-mobile type="image/webp" media="(max-width: 700px)"{% if hero_primary_media.mobileWebpSrcset|default('') %} srcset="{{ hero_primary_media.mobileWebpSrcset|e('html_attr') }}"{% endif %}{% if hero_primary_media.mobileSizes|default('') %} sizes="{{ hero_primary_media.mobileSizes|e('html_attr') }}"{% endif %}>
        <source data-hero-source-jpg-mobile type="image/jpeg" media="(max-width: 700px)"{% if hero_primary_media.mobileSrcset|default('') %} srcset="{{ hero_primary_media.mobileSrcset|e('html_attr') }}"{% endif %}{% if hero_primary_media.mobileSizes|default('') %} sizes="{{ hero_primary_media.mobileSizes|e('html_attr') }}"{% endif %}>
        <source data-hero-source-avif type="image/avif"{% if hero_primary_media.avifSrcset|default('') %} srcset="{{ hero_primary_media.avifSrcset|e('html_attr') }}"{% endif %}>
        <source data-hero-source-webp type="image/webp"{% if hero_primary_media.webpSrcset|default('') %} srcset="{{ hero_primary_media.webpSrcset|e('html_attr') }}"{% endif %}>
        <img
          class="nc-home-hero-media-image"
          data-hero-image
          src="{{ hero_primary_media.src|e('html_attr') }}"
          {% if hero_primary_media.srcset|default('') %}srcset="{{ hero_primary_media.srcset|e('html_attr') }}"{% endif %}
          sizes="{{ hero_primary_media.sizes|default('100vw')|e('html_attr') }}"
          alt=""
          decoding="async"
          loading="eager"
          fetchpriority="high"
        >
      </picture>
    </div>
    <div class="nc-home-hero-overlay" aria-hidden="true"></div>
  {% endif %}
  {% if hero_media|length > 1 %}
    <div class="nc-home-hero-controls" data-hero-controls role="group" aria-label="Controles do carrossel da hero">
      <button type="button" class="nc-home-hero-arrow-btn" data-hero-prev aria-label="Imagem anterior">
        <span class="nc-home-hero-control-icon" aria-hidden="true">&#8249;</span>
        <span class="nc-sr-only">Imagem anterior</span>
      </button>
      <button type="button" class="nc-home-hero-arrow-btn" data-hero-next aria-label="Proxima imagem">
        <span class="nc-home-hero-control-icon" aria-hidden="true">&#8250;</span>
        <span class="nc-sr-only">Proxima imagem</span>
      </button>
      <div class="nc-home-hero-bottom-controls">
        <div class="nc-home-hero-dots" data-hero-dots role="group" aria-label="Selecionar imagem da hero">
          {% for media in hero_media %}
            <button
              type="button"
              class="nc-home-hero-dot{% if loop.first %} is-active{% endif %}"
              data-hero-dot
              data-hero-index="{{ loop.index0 }}"
              aria-label="Ir para imagem {{ loop.index }} de {{ hero_media|length }}"
              {% if loop.first %}aria-current="true"{% endif %}
            ></button>
          {% endfor %}
        </div>
        <button
          type="button"
          class="nc-home-hero-control-btn"
          data-hero-toggle
          aria-pressed="false"
          data-label-play="Reproduzir"
          data-label-pause="Pausar"
        >Pausar</button>
      </div>
      <p class="nc-sr-only" data-hero-status aria-live="off" aria-atomic="true"></p>
    </div>
  {% endif %}

  <div class="nc-hero-grid{% if not show_hero_panel %} is-single-column{% endif %}">
    <div class="nc-hero-copy-stack" data-hero-copy-stack data-aos="fade-up" data-aos-delay="80">
      {% if hero_primary_media %}
        <span class="nc-sr-only" data-hero-copy-image-alt>{{ hero_primary_image_alt }}</span>
      {% endif %}
      <p class="nc-badge nc-hero-terminal-badge" data-hero-copy-badge{% if hero_primary_badge is null or hero_primary_badge|trim == '' %} hidden{% endif %}>
        <span data-hero-copy-badge-code>{{ hero_primary_badge }}</span>
      </p>
      <h1 class="nc-title" data-hero-copy-title>{{ hero_primary_title }}</h1>
      <p class="nc-hero-tagline" data-hero-copy-tagline{% if not hero_primary_has_tagline %} hidden{% endif %}>{{ hero_primary_tagline }}</p>
      <p class="nc-lead" data-hero-copy-lead>{{ hero_primary_lead }}</p>
      <div class="nc-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="{{ hero.actionsDelay|default(140) }}">
        {% for action in hero_actions %}
          {% set action_href = action.href|default('#') %}
          <a
            class="{{ action.class|default('nc-btn nc-btn-primary') }}"
            href="{{ action_href }}"
            {% if action.loadingOnClick|default(false) %}data-loading-on-click{% endif %}
            {% if action.ariaDisabled|default(false) %}aria-disabled="true" tabindex="-1"{% endif %}
          >{{ action.ariaDisabled|default(false) ? action.disabledLabel|default('Em breve') : action.label|default('Saiba mais') }}</a>
        {% endfor %}
      </div>
    </div>
    {% if show_hero_panel %}
      <aside class="nc-hero-panel" aria-label="Indicadores da plataforma" data-aos="fade-left" data-aos-delay="{{ hero.panelDelay|default(180) }}">
        <h2 class="nc-hero-panel-title">{{ hero.panelTitle|default('Indicadores da plataforma') }}</h2>
        <ul class="nc-metric-list">
          {% for metric in hero_metrics %}
            <li class="nc-metric-item" data-aos="fade-up" data-aos-delay="{{ metric.delay|default(220 + (loop.index0 * 60)) }}">
              <span class="nc-metric-value">{{ metric.value|default('—') }}</span>
              <span class="nc-metric-label">{{ metric.label|default('Indicador') }}</span>
            </li>
          {% endfor %}
        </ul>
        {% if hero_qr_url and hero_qr_image %}
          <div class="nc-hero-qr" data-aos="fade-up" data-aos-delay="{{ hero.qrDelay|default(460) }}">
            <h3 class="nc-hero-qr-title">{{ hero.qrTitle|default('Acesse no celular') }}</h3>
            <p class="nc-hero-qr-lead">{{ hero.qrLead|default('Aponte a camera para a tela do dispositivo para abrir o site sem digitar na barra do navegador.') }}</p>
            <a class="nc-hero-qr-link" href="{{ hero_qr_url }}" target="_blank" rel="noopener noreferrer" aria-label="Abrir {{ hero_qr_url }} em uma nova aba">
              <img class="nc-hero-qr-image" src="{{ hero_qr_image }}" alt="{{ hero.qrAlt|default('QR code para abrir o site no celular') }}">
            </a>
            <a class="nc-link nc-hero-qr-fallback" href="{{ hero_qr_url }}" target="_blank" rel="noopener noreferrer">{{ hero_qr_url|replace({'https://': '', 'http://': ''}) }}</a>
          </div>
        {% endif %}
      </aside>
    {% endif %}
  </div>
</section>
