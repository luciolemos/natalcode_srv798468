<section id="testemunhos" class="nc-section nc-home-testimonials" aria-label="Testemunhos" data-aos="fade-up" data-aos-delay="0">
  {% set testimonials_section = homeContent.sections.testimonials|default({}) %}
  {% set testimonials = homeContent.socialProofTestimonials|default([]) %}

  {% include 'components/section-header.twig' with {
    kicker: testimonials_section.kicker|default('Testemunhos'),
    title: testimonials_section.title|default('Depoimentos e testemunhos'),
    lead: testimonials_section.lead|default('Relatos de clientes atendidos pela NatalCode em projetos digitais.')
  } %}

  {% if testimonials|length > 0 %}
    <div class="nc-testimonial-grid" data-testimonials-grid>
      {% for person in testimonials %}
        {% set person_name = person.name|default('Cliente NatalCode') %}
        {% set person_avatar = person.avatar|default('') %}
        {% set person_alt = person.alt|default(person_name) %}
        {% set testimonial_delay = person.delay|default(160 + (loop.index0 * 60)) %}
        <article class="nc-testimonial-card" data-aos="fade-up" data-aos-delay="{{ testimonial_delay }}" style="--testimonial-enter-delay: {{ testimonial_delay }}ms;"{% if loop.index > 3 %} hidden data-testimonial-extra="true"{% endif %}>
          <div class="nc-testimonial-head">
            {% if person_avatar %}
              <img class="nc-testimonial-avatar" src="{{ person_avatar }}" alt="{{ person_alt }}">
            {% else %}
              <span class="nc-testimonial-avatar nc-testimonial-avatar-fallback" aria-hidden="true">{{ person_name|slice(0, 1)|upper }}</span>
            {% endif %}
            <div class="nc-testimonial-meta">
              <strong class="nc-testimonial-name">{{ person_name }}</strong>
              <span class="nc-testimonial-role">{{ person.role|default('Cliente') }}</span>
            </div>
          </div>
          <p>"{{ person.quote|default('Depoimento em atualização.') }}"</p>
        </article>
      {% endfor %}
    </div>

    {% if testimonials|length > 3 %}
      <div class="nc-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="180">
        <button class="nc-btn nc-btn-primary" type="button" data-testimonials-toggle aria-expanded="false">Ver mais depoimentos</button>
      </div>
    {% endif %}
  {% endif %}
</section>
