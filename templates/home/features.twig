<section id="estudos" class="nc-section nc-studies-overview" aria-label="Servicos principais">
  {% set features_section = homeContent.sections.features|default({}) %}
  {% set features_items = homeContent.featuresItems|default([]) %}

  {% include 'components/section-header.twig' with {
    kicker: features_section.kicker|default('Servicos'),
    title: features_section.title|default('Solucoes digitais para crescimento do negocio'),
    lead: features_section.lead|default('Desenvolvimento web, landing pages e suporte continuo para aumentar resultado.')
  } %}
  <div class="nc-feature-grid nc-tonal-feature-grid">
    {% for item in features_items %}
      {% include 'components/feature-card.twig' with {
        title: item.title,
        description: item.description,
        href: item.href|default(''),
        link_label: item.linkLabel|default('Saiba mais'),
        delay: item.delay
      } %}
    {% endfor %}
  </div>
</section>
