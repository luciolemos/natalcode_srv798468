<section id="estudos" class="nc-section" aria-label="Estudos principais">
  {% set features_section = homeContent.sections.features|default({}) %}
  {% set features_items = homeContent.featuresItems|default([]) %}

  {% include 'components/section-header.twig' with {
    kicker: features_section.kicker|default('Estudos'),
    title: features_section.title|default('Iluminando consciências através do conhecimento'),
    lead: features_section.lead|default('Oferecemos grupos de estudo sistematizado, palestras públicas e atendimento fraterno para todos que buscam compreender a vida além da matéria.')
  } %}
  <div class="nc-feature-grid">
    {% for item in features_items %}
      {% include 'components/feature-card.twig' with {
        title: item.title,
        description: item.description,
        delay: item.delay
      } %}
    {% endfor %}
  </div>
</section>
