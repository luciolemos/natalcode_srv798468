<section id="agenda" class="nc-section" aria-label="Agenda semanal">
  {% set roadmap_section = homeContent.sections.roadmap|default({}) %}
  {% set roadmap_items = homeContent.roadmapItems|default([]) %}

  {% include 'components/section-header.twig' with {
    kicker: roadmap_section.kicker|default('Agenda'),
    title: roadmap_section.title|default('Cronograma Semanal de Atividades'),
    lead: roadmap_section.lead|default('Confira nossos horários de reuniões públicas, estudos e assistência espiritual. Todas as atividades são gratuitas.')
  } %}
  <ul class="nc-checklist">
    {% for item in roadmap_items %}
      {% include 'components/check-item.twig' with {
        step: item.step,
        title: item.title,
        description: item.description,
        delay: item.delay
      } %}
    {% endfor %}
  </ul>
</section>
