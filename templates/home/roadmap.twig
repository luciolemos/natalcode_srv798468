<section id="agenda" class="nc-section" aria-label="Processo de projeto">
  {% set roadmap_section = homeContent.sections.roadmap|default({}) %}
  {% set roadmap_items = homeContent.roadmapItems|default([]) %}

  {% include 'components/section-header.twig' with {
    kicker: roadmap_section.kicker|default('Processo'),
    title: roadmap_section.title|default('Etapas de entrega'),
    lead: roadmap_section.lead|default('Fluxo de trabalho com etapas claras para planejar, implementar e otimizar seu projeto digital.')
  } %}
  <ul class="nc-checklist">
    {% for item in roadmap_items %}
      {% include 'components/check-item.twig' with {
        step: item.step|default(item.phase),
        title: item.title,
        description: item.description,
        href: item.href|default(''),
        link_label: item.linkLabel|default('Saiba mais'),
        delay: item.delay
      } %}
    {% endfor %}
  </ul>
</section>
