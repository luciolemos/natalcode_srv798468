{% set path = current_path|default('/') %}
{% set trimmed_path = path|trim('/') %}
{% set segments = trimmed_path == '' ? [] : trimmed_path|split('/') %}
{% set fallback_labels = {
  'quem-somos': 'Quem Somos',
  'missao': 'Missao',
  'valores': 'Valores',
  'historia': 'Historia',
  'fundador': 'Liderança',
  'estatuto': 'Diretrizes',
  'nossa-marca': 'Nossa Marca',
  'gestao-cede': 'Gestão NatalCode',
  'equipe': 'Gestão NatalCode',
  'estudos': 'Serviços',
  'eade': 'Sites Institucionais',
  'esde': 'Landing Pages',
  'palestras': 'SEO e Conteúdo',
  'atendimento-fraterno': 'Suporte e Manutenção',
  'agenda': 'Processo',
  'estudo-do-evangelho': 'Descoberta',
  'palestra-publica': 'Implementação',
  'juventude-espirita': 'Otimização',
  'loja': 'Recursos',
  'bazar': 'Materiais',
  'livraria': 'NatalCode Labs',
  'livraria-ii': 'NatalCode Labs',
  'livraria-auta-de-sousa': 'NatalCode Labs',
  'faq': 'FAQ',
  'biblioteca': 'Base de conhecimento',
  'base-de-conhecimento': 'Base de conhecimento',
  'doutrina': 'Estratégia',
  'participacao': 'Contratação',
  'praticas': 'Entrega',
  'dados-de-acesso': 'Dados de acesso',
  'contato': 'Contato'
} %}
{% set labels = navigation_labels|default(fallback_labels) %}

{% if segments|length > 1 %}
  <div class="nc-breadcrumbs-wrap">
    <div class="nc-container">
      <nav class="nc-breadcrumbs" aria-label="Breadcrumb">
        <a class="nc-breadcrumb-link" href="/">Início</a>
        {% set path_accumulator = '' %}
        {% for segment in segments %}
          {% set path_accumulator = path_accumulator ~ '/' ~ segment %}
          {% set label = labels[segment]|default(segment|replace({'-': ' '})|capitalize) %}
          <span class="nc-breadcrumb-separator" aria-hidden="true">/</span>
          {% if loop.last %}
            <span class="nc-breadcrumb-current" aria-current="page">{{ label }}</span>
          {% else %}
            <a class="nc-breadcrumb-link" href="{{ path_accumulator }}">{{ label }}</a>
          {% endif %}
        {% endfor %}
      </nav>
    </div>
  </div>
{% endif %}
