<footer id="contato" class="nc-footer">
  <div class="nc-container nc-footer-layout">
    <section class="nc-footer-block nc-footer-brand-block" aria-label="Identidade institucional">
      <a class="nc-footer-brand" href="/" aria-label="CEDE - Início">
        <img
          src="{{ base_url ?? '' }}/assets/img/brands/cedern.png"
          alt="{{ app_name ?? 'CEDE' }} (tema escuro)"
          class="footer-logo logo-dark"
        >
        <img
          src="{{ base_url ?? '' }}/assets/img/brands/cedern.png"
          alt="{{ app_name ?? 'CEDE' }} (tema claro)"
          class="footer-logo logo-light"
        >
      </a>
      <p class="nc-footer-copy">Centro de Estudos da Doutrina Espírita (CEDE)</p>
      <p class="nc-footer-copy">Estudo, acolhimento fraterno e prática do bem à luz do Espiritismo.</p>
    </section>

    <nav class="nc-footer-block" aria-label="Links institucionais">
      <h3 class="nc-footer-title">Institucional</h3>
      <ul class="nc-footer-links">
        <li><a class="nc-footer-link" href="/">Início</a></li>
        <li><a class="nc-footer-link" href="/quem-somos">Quem Somos</a></li>
        <li><a class="nc-footer-link" href="/quem-somos/nossa-marca">Nossa Marca</a></li>
        <li><a class="nc-footer-link" href="/estudos">Estudos</a></li>
        <li><a class="nc-footer-link" href="/agenda">Agenda</a></li>
        <li><a class="nc-footer-link" href="/faq">FAQ</a></li>
      </ul>
    </nav>

    <section class="nc-footer-block" aria-label="Informações de contato">
      <h3 class="nc-footer-title">Contato</h3>
      {% if app_address is defined and app_address %}
        <p class="nc-footer-copy">{{ app_address }}</p>
      {% endif %}
      <p class="nc-footer-copy">
        <a class="nc-footer-link" href="mailto:cede@cedern.org">cede@cedern.org</a>
      </p>
      {% if app_instagram_url is defined and app_instagram_url %}
        <p class="nc-footer-copy">
          <a class="nc-footer-link" href="{{ app_instagram_url }}" target="_blank" rel="noopener noreferrer">{{ app_instagram_label|default('Instagram oficial') }}</a>
        </p>
      {% endif %}
    </section>
  </div>

  <div class="nc-container nc-footer-bottom">
    <p class="nc-footer-copy">© {{ "now"|date("Y") }} CEDE. Todos os direitos reservados.</p>
  </div>
</footer>
