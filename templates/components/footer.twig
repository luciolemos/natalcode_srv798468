{% set footer = site.footer|default({}) %}
{% set footer_nav_groups = footer.navGroups|default([]) %}
{% set brand = site.brand|default({}) %}
{% set brand_logo_default = '/assets/img/brand/natalcode2_logo_horizontal_black_1158x314.png' %}
{% set brand_logo_src = brand.logoSrc|default(brand_logo_default) %}
{% set brand_logo_dark_src = brand.logoDarkSrc|default(brand_logo_src) %}
{% set brand_logo_light_src = brand.logoLightSrc|default(brand_logo_src) %}
{% set social = site.social|default({}) %}
{% set social_links = [] %}
{% if social.instagram.url|default('') %}
  {% set social_links = social_links|merge([{
    platform: 'instagram',
    href: social.instagram.url,
    label: social.instagram.label|default('Instagram')
  }]) %}
{% endif %}
{% if social.facebook.url|default('') %}
  {% set social_links = social_links|merge([{
    platform: 'facebook',
    href: social.facebook.url,
    label: social.facebook.label|default('Facebook')
  }]) %}
{% endif %}
{% if social.github.url|default('') %}
  {% set social_links = social_links|merge([{
    platform: 'github',
    href: social.github.url,
    label: social.github.label|default('GitHub')
  }]) %}
{% endif %}

<footer id="contato" class="nc-footer">
  <div class="nc-container">
    <div class="nc-footer-layout">
      <section class="nc-footer-block nc-footer-brand-block" aria-label="Identidade institucional">
        <a class="nc-footer-brand" href="{{ brand.homeHref|default('/') }}" aria-label="{{ site.name|default('NatalCode') }} - Início">
          <img
            src="{{ (base_url ?? '') ~ brand_logo_dark_src }}"
            alt="{{ brand.logoAlt|default(site.name|default('NatalCode')) }} (tema escuro)"
            class="footer-logo logo-dark"
          >
          <img
            src="{{ (base_url ?? '') ~ brand_logo_light_src }}"
            alt="{{ brand.logoAlt|default(site.name|default('NatalCode')) }} (tema claro)"
            class="footer-logo logo-light"
          >
        </a>
        {% if footer.kicker|default('') %}
          <p class="nc-footer-kicker">{{ footer.kicker }}</p>
        {% endif %}
        <p class="nc-footer-heading">{{ site.legalName|default(site.name|default('NatalCode')) }}</p>
        <p class="nc-footer-copy">{{ footer.description|default(site.tagline|default('')) }}</p>
      </section>

      <div class="nc-footer-nav-grid">
        {% for group in footer_nav_groups %}
          {% set group_title = group.title|default('Links') %}
          {% set group_modifier = '' %}
          {% if group_title == 'Institucional' %}
            {% set group_modifier = ' is-institutional' %}
          {% elseif group_title == 'Loja' or group_title == 'Recursos' %}
            {% set group_modifier = ' is-store' %}
          {% endif %}
          <nav class="nc-footer-block nc-footer-nav-column{{ group_modifier }}" aria-label="{{ group_title|default('Navegação do rodapé') }}">
            <h3 class="nc-footer-title">{{ group_title|default('Links') }}</h3>
            {% if group.links|default([]) %}
              <ul class="nc-footer-links">
                {% for link in group.links %}
                  <li><a class="nc-footer-link" href="{{ link.path }}">{{ link.label|default(link.path) }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </nav>
        {% endfor %}

        {% if social_links|length > 0 %}
          <nav class="nc-footer-block nc-footer-social-block" aria-label="Redes sociais institucionais">
            <h3 class="nc-footer-title">Redes sociais</h3>
            <ul class="nc-footer-social-links">
              {% for social_link in social_links %}
                <li>
                  <a class="nc-footer-social-link" href="{{ social_link.href }}" target="_blank" rel="noopener noreferrer" aria-label="{{ social_link.label }}">
                    {% if social_link.platform == 'instagram' %}
                      <svg class="nc-footer-social-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <rect x="4" y="4" width="16" height="16" rx="4.5" stroke="currentColor" stroke-width="1.8"/>
                        <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.8"/>
                        <circle cx="16.5" cy="7.5" r="0.9" fill="currentColor"/>
                      </svg>
                    {% elseif social_link.platform == 'facebook' %}
                      <svg class="nc-footer-social-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/>
                        <path d="M13.5 8H12C11.4477 8 11 8.44772 11 9V11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M9.5 11H13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        <path d="M11 11V19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                      </svg>
                    {% elseif social_link.platform == 'github' %}
                      <svg class="nc-footer-social-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M12 3C7.029 3 3 7.029 3 12C3 15.979 5.582 19.353 9.157 20.543C9.607 20.625 9.771 20.353 9.771 20.12C9.771 19.913 9.764 19.363 9.761 18.633C7.259 19.177 6.731 17.428 6.731 17.428C6.322 16.39 5.733 16.114 5.733 16.114C4.917 15.556 5.795 15.567 5.795 15.567C6.697 15.631 7.171 16.494 7.171 16.494C7.973 17.87 9.276 17.472 9.79 17.241C9.872 16.66 10.104 16.262 10.36 16.037C8.363 15.81 6.263 15.038 6.263 11.588C6.263 10.605 6.614 9.803 7.192 9.172C7.099 8.946 6.79 8.037 7.279 6.807C7.279 6.807 8.035 6.565 9.754 7.727C10.474 7.527 11.245 7.427 12.014 7.423C12.783 7.427 13.554 7.527 14.275 7.727C15.993 6.565 16.748 6.807 16.748 6.807C17.238 8.037 16.929 8.946 16.836 9.172C17.415 9.803 17.764 10.605 17.764 11.588C17.764 15.047 15.66 15.807 13.658 16.03C13.979 16.307 14.265 16.853 14.265 17.691C14.265 18.893 14.254 19.86 14.254 20.12C14.254 20.355 14.416 20.629 14.872 20.542C18.447 19.351 21.027 15.978 21.027 12C21.027 7.029 16.998 3 12.027 3H12Z"/>
                      </svg>
                    {% endif %}
                    <span>{{ social_link.label }}</span>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        {% endif %}
      </div>

    </div>

    <div class="nc-footer-bottom">
      <p class="nc-footer-copy">© {{ "now"|date("Y") }} {{ site.name|default('NatalCode') }}. Todos os direitos reservados.</p>
      {% if footer.bottomNote|default('') %}
        <p class="nc-footer-copy">{{ footer.bottomNote }}</p>
      {% endif %}
    </div>
  </div>
</footer>
