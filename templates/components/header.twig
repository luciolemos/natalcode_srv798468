<header class="nc-header">
  {% set path = current_path|default('') %}
  {% set labels = navigation_labels|default({}) %}
  {% set nav_groups = navigation_menu|default([]) %}
  {% set nav_links_before = navigation_links_before_groups|default([]) %}
  {% set nav_links_after = navigation_links_after_groups|default([]) %}

  <div class="nc-container nc-header-row">
    <a class="nc-brand" href="/" aria-label="CEDE - Início">
      
      <img
        src="{{ base_url ?? '' }}/assets/img/brands/cede4_logo.png"
        alt="{{ app_name ?? 'Labs' }} (tema escuro)"
        class="navbar-logo logo-dark"
      >
      <img
        src="{{ base_url ?? '' }}/assets/img/brands/cede4_logo.png"
        alt="{{ app_name ?? 'Labs' }} (tema claro)"
        class="navbar-logo logo-light"
      >
      
      {# <span class="nc-brand-name">{{ app_name ?? 'CEDE' }}</span> #}
    </a>
    <button
      class="nc-nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="nc-nav-menu"
      aria-label="Abrir menu"
    >
      <span class="nc-nav-toggle-bar"></span>
      <span class="nc-nav-toggle-bar"></span>
      <span class="nc-nav-toggle-bar"></span>
    </button>
    <nav id="nc-nav-menu" class="nc-nav" aria-label="Navegação principal" hidden>
      {% for item in nav_links_before %}
        {% set is_item_active = path == item.path %}
        <a class="nc-link{{ is_item_active ? ' is-active' : '' }}" href="{{ item.path }}" {% if is_item_active %}aria-current="page"{% endif %}>{{ item.key is defined ? labels[item.key]|default(item.label|default(item.path)) : item.label|default(item.path) }}</a>
      {% endfor %}

      {% for group in nav_groups %}
        {% set is_group_active = path starts with group.base %}
        <div class="nc-nav-group{{ is_group_active ? ' is-active' : '' }}" data-nav-group>
          <button class="nc-nav-group-toggle{{ is_group_active ? ' is-active' : '' }}" type="button" aria-expanded="false" aria-controls="nc-submenu-{{ group.key }}" {% if is_group_active %}aria-current="page"{% endif %}>
            {{ labels[group.key]|default(group.label|default(group.key)) }}
          </button>
          <div id="nc-submenu-{{ group.key }}" class="nc-nav-submenu" hidden>
            {% for item in group.items %}
              {% set is_item_active = path == item.path %}
              <a class="nc-nav-submenu-link{{ is_item_active ? ' is-active' : '' }}" href="{{ item.path }}" {% if is_item_active %}aria-current="page"{% endif %}>
                {{ item.key is defined ? labels[item.key]|default(item.label|default(item.path)) : item.label|default(item.path) }}
              </a>
            {% endfor %}
          </div>
        </div>
      {% endfor %}

      {% for item in nav_links_after %}
        {% set is_login_entry = item.key is defined and item.key == 'login' %}
        {% if not is_login_entry %}
          {% set is_item_active = path == item.path %}
          <a class="nc-link{{ is_item_active ? ' is-active' : '' }}" href="{{ item.path }}" {% if is_item_active %}aria-current="page"{% endif %}>{{ item.key is defined ? labels[item.key]|default(item.label|default(item.path)) : item.label|default(item.path) }}</a>
        {% endif %}
      {% endfor %}

      {% set auth_is_logged = dashboard_is_authenticated|default(false) %}
      {% set auth_path = auth_is_logged ? '/painel' : '/painel/login' %}
      {% set auth_label = auth_is_logged ? 'PAINEL' : labels.login|default('Login') %}
      {% set auth_is_active = auth_is_logged ? (path starts with '/painel') : (path == '/painel/login') %}

      {% if auth_is_logged %}
        <a class="nc-link nc-link-panel{{ auth_is_active ? ' is-active' : '' }}" href="{{ auth_path }}" {% if auth_is_active %}aria-current="page"{% endif %}>
          <span class="nc-link-panel-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="4" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.8"/>
              <path d="M3 10H21" stroke="currentColor" stroke-width="1.8"/>
              <path d="M8 15H11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </span>
          <span>{{ auth_label }}</span>
        </a>
      {% else %}
        <a class="nc-link{{ auth_is_active ? ' is-active' : '' }}" href="{{ auth_path }}" {% if auth_is_active %}aria-current="page"{% endif %}>{{ auth_label }}</a>
      {% endif %}
    </nav>
  </div>
</header>
