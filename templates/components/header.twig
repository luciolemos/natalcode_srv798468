<header class="nc-header">
  {% set path = current_path|default('') %}
  {% set labels = navigation_labels|default({}) %}
  {% set nav_groups = navigation_menu|default([]) %}
  {% set nav_links_before = navigation_links_before_groups|default([]) %}
  {% set nav_links_after = navigation_links_after_groups|default([]) %}

  <div class="nc-container nc-header-row">
    <a class="nc-brand" href="/" aria-label="CEDE - Início">
      <img
        src="{{ (base_url ?? '') ~ (site.brand.logoSrc|default('/assets/img/brands/cede4_logo.png')) }}"
        alt="{{ site.brand.logoAlt|default(site.name|default('CEDE')) }} (tema escuro)"
        class="navbar-logo logo-dark"
      >
      <img
        src="{{ (base_url ?? '') ~ (site.brand.logoSrc|default('/assets/img/brands/cede4_logo.png')) }}"
        alt="{{ site.brand.logoAlt|default(site.name|default('CEDE')) }} (tema claro)"
        class="navbar-logo logo-light"
      >
      {# <span class="nc-brand-name">{{ app_name ?? 'CEDE' }}</span> #}
    </a>
    <button
      class="nc-nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="nc-nav-menu"
      aria-label="Abrir menu"
    >
      <span class="nc-nav-toggle-bar"></span>
      <span class="nc-nav-toggle-bar"></span>
      <span class="nc-nav-toggle-bar"></span>
    </button>
    <nav id="nc-nav-menu" class="nc-nav" aria-label="Navegação principal" hidden>
      {% for item in nav_links_before %}
        {% set is_item_active = path == item.path %}
        {% set item_label = item.key is defined ? labels[item.key]|default(item.label|default(item.path)) : item.label|default(item.path) %}
        <a class="nc-link{{ is_item_active ? ' is-active' : '' }}" href="{{ item.path }}" {% if is_item_active %}aria-current="page"{% endif %}>
          <span class="nc-nav-link-content">
            {% include 'components/nav-icon.twig' with { icon_key: item.key|default('menu') } only %}
            <span>{{ item_label }}</span>
          </span>
        </a>
      {% endfor %}

      {% for group in nav_groups %}
        {% set is_group_active = path starts with group.base %}
        <div class="nc-nav-group{{ is_group_active ? ' is-active' : '' }}" data-nav-group>
          <button class="nc-nav-group-toggle{{ is_group_active ? ' is-active' : '' }}" type="button" aria-expanded="false" aria-controls="nc-submenu-{{ group.key }}" {% if is_group_active %}aria-current="page"{% endif %}>
            <span class="nc-nav-link-content">
              {% include 'components/nav-icon.twig' with { icon_key: group.key|default('menu') } only %}
              <span>{{ labels[group.key]|default(group.label|default(group.key)) }}</span>
            </span>
          </button>
          <div id="nc-submenu-{{ group.key }}" class="nc-nav-submenu" hidden>
            {% for item in group.items %}
              {% set is_item_active = path == item.path %}
              {% set item_label = item.key is defined ? labels[item.key]|default(item.label|default(item.path)) : item.label|default(item.path) %}
              {% set submenu_icon_key = item.key|default(group.key|default('menu')) %}
              <a class="nc-nav-submenu-link{{ is_item_active ? ' is-active' : '' }}" href="{{ item.path }}" {% if is_item_active %}aria-current="page"{% endif %}>
                <span class="nc-nav-link-content">
                  {% include 'components/nav-icon.twig' with { icon_key: submenu_icon_key } only %}
                  <span>{{ item_label }}</span>
                </span>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endfor %}

      {% for item in nav_links_after %}
        {% set is_login_entry = item.key is defined and item.key == 'login' %}
        {% if not is_login_entry %}
          {% set is_item_active = path == item.path %}
          {% set item_label = item.key is defined ? labels[item.key]|default(item.label|default(item.path)) : item.label|default(item.path) %}
          <a class="nc-link{{ is_item_active ? ' is-active' : '' }}" href="{{ item.path }}" {% if is_item_active %}aria-current="page"{% endif %}>
            <span class="nc-nav-link-content">
              {% include 'components/nav-icon.twig' with { icon_key: item.key|default('menu') } only %}
              <span>{{ item_label }}</span>
            </span>
          </a>
        {% endif %}
      {% endfor %}

      {% set auth_is_logged = dashboard_is_authenticated|default(false) %}
      {% if auth_is_logged %}
        {% set can_admin_notifications = dashboard_is_admin_session|default(false) or member_role_key|default('member') == 'admin' %}
        {% set admin_notification_count = dashboard_admin_notification_count|default(0) %}
        {% if can_admin_notifications %}
          {% set notify_is_active = path starts with '/painel/usuarios' %}
          <a class="nc-link nc-link-notify{{ notify_is_active ? ' is-active' : '' }}" href="/painel/usuarios?sort=created_at&dir=desc&q=pending" {% if notify_is_active %}aria-current="page"{% endif %} aria-label="Notificações administrativas">
            <span class="nc-link-notify-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 4C9.23858 4 7 6.23858 7 9V11.5C7 13.05 6.41071 14.5446 5.35195 15.6841L4 17.1389H20L18.648 15.6841C17.5893 14.5446 17 13.05 17 11.5V9C17 6.23858 14.7614 4 12 4Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 19C10.4174 19.6227 11.1318 20 12 20C12.8682 20 13.5826 19.6227 14 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
            {% if admin_notification_count > 0 %}
              <span class="nc-link-notify-badge" aria-live="polite">{{ admin_notification_count }}</span>
            {% endif %}
          </a>
        {% endif %}
      {% endif %}

      {% set member_is_logged = member_is_authenticated|default(false) %}
      {% if member_is_logged %}
        {% set member_has_panel_access = dashboard_is_authenticated|default(false) %}
        {% set member_area_active = path starts with '/membro' or path starts with '/painel' %}
        {% set member_display_name = member_name|default('Membro') %}
        {% set member_role_label = member_role_name|default('Membro') %}
        {% set member_photo_path = member_profile_photo_path|default('') %}
        <div class="nc-nav-group nc-member-nav-group{{ member_area_active ? ' is-active' : '' }}" data-nav-group>
          <button class="nc-nav-group-toggle nc-member-nav-toggle{{ member_area_active ? ' is-active' : '' }}" type="button" aria-expanded="false" aria-controls="nc-submenu-member-user" {% if member_area_active %}aria-current="page"{% endif %}>
            <span class="nc-member-nav-avatar" aria-hidden="true">
              {% if member_photo_path %}
                <img src="/{{ member_photo_path }}" alt="">
              {% else %}
                <span>{{ member_display_name|slice(0, 1)|upper }}</span>
              {% endif %}
            </span>
            <span class="nc-member-nav-meta">
              <span class="nc-member-nav-name">{{ member_display_name }}</span>
              <span class="nc-member-nav-role">{{ member_role_label }}</span>
            </span>
          </button>
          <div id="nc-submenu-member-user" class="nc-nav-submenu" hidden>
            {% if member_has_panel_access %}
              <a class="nc-nav-submenu-link{{ path starts with '/painel' ? ' is-active' : '' }}" href="/painel" {% if path starts with '/painel' %}aria-current="page"{% endif %}>
                <span class="nc-nav-link-content">
                  {% include 'components/nav-icon.twig' with { icon_key: 'painel' } only %}
                  <span>PAINEL</span>
                </span>
              </a>
            {% endif %}
            <a class="nc-nav-submenu-link{{ path == '/membro' ? ' is-active' : '' }}" href="/membro" {% if path == '/membro' %}aria-current="page"{% endif %}>
              <span class="nc-nav-link-content">
                {% include 'components/nav-icon.twig' with { icon_key: 'member-area' } only %}
                <span>Minha Área</span>
              </span>
            </a>
            <a class="nc-nav-submenu-link{{ path starts with '/membro/perfil' ? ' is-active' : '' }}" href="/membro/perfil/completar" {% if path starts with '/membro/perfil' %}aria-current="page"{% endif %}>
              <span class="nc-nav-link-content">
                {% include 'components/nav-icon.twig' with { icon_key: 'quem-somos' } only %}
                <span>Editar Perfil</span>
              </span>
            </a>
            <a class="nc-nav-submenu-link" href="/membro/sair">
              <span class="nc-nav-link-content">
                {% include 'components/nav-icon.twig' with { icon_key: 'logout' } only %}
                <span>Sair</span>
              </span>
            </a>
          </div>
        </div>
      {% else %}
        {% set member_login_active = path == '/entrar' %}
        {% set member_register_active = path == '/cadastro' %}
        <a class="nc-link{{ member_register_active ? ' is-active' : '' }}" href="/cadastro" {% if member_register_active %}aria-current="page"{% endif %}>
          <span class="nc-nav-link-content">
            {% include 'components/nav-icon.twig' with { icon_key: 'cadastrar' } only %}
            <span>Cadastrar</span>
          </span>
        </a>
        <a class="nc-link{{ member_login_active ? ' is-active' : '' }}" href="/entrar" {% if member_login_active %}aria-current="page"{% endif %}>
          <span class="nc-nav-link-content">
            {% include 'components/nav-icon.twig' with { icon_key: 'entrar' } only %}
            <span>Entrar</span>
          </span>
        </a>
      {% endif %}
    </nav>
  </div>
</header>
