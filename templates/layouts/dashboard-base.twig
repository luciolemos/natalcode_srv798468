<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% set page_title = page_title|default(app_default_page_title|default('Dashboard | CEDE')) %}
  {% set page_description = page_description|default(app_default_page_description|default('Área interna administrativa.')) %}
  {% set page_url = page_url|default(app_default_page_url|default('https://cedern.org/dashboard')) %}
  {% set page_image = page_image|default(app_default_page_image|default('https://cedern.org/assets/img/cedern/cede1_1600_1000.png')) %}
  {% set site_name = site_name|default(app_default_site_name|default('CEDE')) %}
  {% set twitter_site = twitter_site|default(app_default_twitter_site|default('@cedeoficialrn')) %}
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ page_description }}">
  <meta property="og:title" content="{{ page_title }}">
  <meta property="og:description" content="{{ page_description }}">
  <meta property="og:url" content="{{ page_url }}">
  <meta property="og:image" content="{{ page_image }}">
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="pt_BR">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title }}">
  <meta name="twitter:description" content="{{ page_description }}">
  <meta name="twitter:image" content="{{ page_image }}">
  <meta name="twitter:site" content="{{ twitter_site }}">
  <script>
    (function () {
      try {
        var root = document.documentElement;
        var allowedThemes = ['blue', 'red', 'green', 'violet', 'amber'];
        var allowedModes = ['light', 'dark'];
        var allowedDarkIntensities = ['neutral', 'vivid'];

        var savedTheme = (localStorage.getItem('natalcode_theme') || '').toLowerCase();
        var savedMode = (localStorage.getItem('natalcode_mode') || '').toLowerCase();
        var savedDarkIntensity = (localStorage.getItem('natalcode_dark_intensity') || '').toLowerCase();

        if (allowedThemes.indexOf(savedTheme) !== -1) {
          root.setAttribute('data-theme', savedTheme);
        }

        if (allowedModes.indexOf(savedMode) !== -1) {
          root.setAttribute('data-mode', savedMode);
        }

        if (allowedDarkIntensities.indexOf(savedDarkIntensity) !== -1) {
          root.setAttribute('data-dark-intensity', savedDarkIntensity);
        }

        var isDesktop = window.matchMedia && window.matchMedia('(min-width: 981px)').matches;
        var savedSidebarCollapsed = localStorage.getItem('natalcode_dashboard_sidebar_collapsed') === '1';

        if (isDesktop && savedSidebarCollapsed) {
          root.setAttribute('data-dashboard-sidebar-collapsed', '1');
        } else {
          root.removeAttribute('data-dashboard-sidebar-collapsed');
        }
      } catch (error) {
      }
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Lora:wght@500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
  {% set asset_version = app_asset_version|default('1') %}
  <link rel="stylesheet" href="/assets/css/cedern.css?v={{ asset_version }}">
  <script src="/assets/js/cedern-theme.js?v={{ asset_version }}" defer></script>
</head>
<body data-default-theme="{{ default_theme|default('amber') }}" data-default-mode="{{ default_mode|default('light') }}" data-default-dark-intensity="{{ default_dark_intensity|default('neutral') }}">
  {% block content %}{% endblock %}
  {% include 'components/theme-palette.twig' %}
</body>
</html>
