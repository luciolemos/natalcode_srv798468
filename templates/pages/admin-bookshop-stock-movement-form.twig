{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = bookshop_stock_movement_mode == 'adjustment' ? 'Novo ajuste de estoque' : 'Nova entrada de estoque' %}
{% set dashboard_page_lead = bookshop_stock_movement_mode == 'adjustment'
  ? 'Ajuste o saldo físico do acervo sempre que houver divergência, perda, avaria ou correção operacional.'
  : 'Registre a entrada de novos exemplares ou doações recebidas para manter o saldo físico da livraria atualizado.' %}
{% set selected_book_query = bookshop_stock_movement_form.book_id|default(0) > 0 ? '&book_id=' ~ bookshop_stock_movement_form.book_id : '' %}

{% block admin_content %}
  <section class="nc-section" aria-label="Formulário de movimentação de estoque da livraria" data-aos="fade-up" data-aos-delay="0">
    {% if bookshop_stock_movement_form_errors|length > 0 %}
      <article class="nc-admin-form-errors" role="alert">
        <strong>Corrija os campos abaixo:</strong>
        <ul>
          {% for error in bookshop_stock_movement_form_errors %}
            <li>{{ error }}</li>
          {% endfor %}
        </ul>
      </article>
    {% endif %}

    <div class="nc-actions nc-bookshop-toolbar" data-aos="fade-up" data-aos-delay="60">
      <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel">Voltar ao painel</a>
      <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel/livraria/movimentacoes">Voltar ao histórico</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/acervo">Abrir acervo</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/vendas">Vendas PDV</a>
      <div class="nc-bookshop-toolbar-actions-pair">
        <a class="nc-btn {{ bookshop_stock_movement_mode == 'entry' ? 'nc-btn-primary' : 'nc-btn-secondary' }}" href="/painel/livraria/movimentacoes/nova?mode=entry{{ selected_book_query }}" {% if bookshop_stock_movement_mode == 'entry' %}aria-current="page"{% endif %}>Nova entrada</a>
        <a class="nc-btn {{ bookshop_stock_movement_mode == 'adjustment' ? 'nc-btn-primary' : 'nc-btn-secondary' }}" href="/painel/livraria/movimentacoes/nova?mode=adjustment{{ selected_book_query }}" {% if bookshop_stock_movement_mode == 'adjustment' %}aria-current="page"{% endif %}>Novo ajuste</a>
      </div>
    </div>

    <article class="nc-card nc-admin-form-card">
      <div class="nc-bookshop-form-metrics">
        <div class="nc-bookshop-form-metric">
          <span class="nc-metric-label">Livro selecionado</span>
          <strong data-bookshop-movement-summary-title>Nenhum livro</strong>
        </div>
        <div class="nc-bookshop-form-metric">
          <span class="nc-metric-label">Saldo atual</span>
          <strong data-bookshop-movement-summary-stock>0</strong>
        </div>
        <div class="nc-bookshop-form-metric">
          <span class="nc-metric-label">Impacto da movimentação</span>
          <strong data-bookshop-movement-summary-delta>+0</strong>
        </div>
        <div class="nc-bookshop-form-metric">
          <span class="nc-metric-label">Saldo projetado</span>
          <strong data-bookshop-movement-summary-projected>0</strong>
        </div>
      </div>

      <form class="nc-admin-form" method="post" action="/painel/livraria/movimentacoes/nova?mode={{ bookshop_stock_movement_mode }}" data-bookshop-stock-movement-form data-bookshop-stock-movement-mode="{{ bookshop_stock_movement_mode }}" data-bookshop-options="{{ bookshop_stock_movement_book_options|json_encode|e('html_attr') }}">
          {% include 'components/csrf-field.twig' %}
        <input type="hidden" name="mode" value="{{ bookshop_stock_movement_form.mode|default(bookshop_stock_movement_mode) }}">

        {% if bookshop_stock_movement_mode == 'adjustment' %}
          <p class="nc-admin-form-note">
            <strong>Como funciona o ajuste:</strong>
            ajuste positivo soma unidades ao lote (custo e preço só mudam se você preencher);
            ajuste negativo e perda/avaria apenas reduzem a quantidade e não alteram custo/preço.
          </p>
        {% endif %}

        <div class="nc-admin-form-grid nc-admin-form-grid-bookshop-stock-movement-head{% if bookshop_stock_movement_mode == 'adjustment' %} nc-admin-form-grid-bookshop-stock-movement-head-adjustment{% endif %}">
          <div class="nc-admin-form-field">
            <label class="nc-admin-form-label" for="book_id">Livro do acervo</label>
            <select class="nc-admin-form-input" id="book_id" name="book_id" required data-bookshop-movement-book-select>
              <option value="" {% if bookshop_stock_movement_form.book_id|default(0) == 0 %}selected{% endif %} disabled>Selecione um livro</option>
              {% for book in bookshop_stock_movement_book_options|default([]) %}
                <option
                  value="{{ book.id }}"
                  data-title="{{ book.title }}"
                  data-author="{{ book.author_name }}"
                  data-sku="{{ book.sku }}"
                  data-stock="{{ book.stock_quantity }}"
                  data-location="{{ book.location_label }}"
                  data-cost-label="{{ book.cost_price_label }}"
                  data-sale-label="{{ book.sale_price_label }}"
                  data-status="{{ book.status_label }}"
                  {{ bookshop_stock_movement_form.book_id|default(0) == book.id ? 'selected' : '' }}
                >{{ book.label }}</option>
              {% endfor %}
            </select>
          </div>

          {% if bookshop_stock_movement_mode == 'adjustment' %}
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="stock_lot_id">Lote do ajuste</label>
              <select class="nc-admin-form-input" id="stock_lot_id" name="stock_lot_id" data-bookshop-movement-lot-select data-selected-lot="{{ bookshop_stock_movement_form.stock_lot_id|default(0) }}" {{ bookshop_stock_movement_lot_required|default(false) ? 'required' : '' }} {{ bookshop_stock_movement_lot_options|default([])|length == 0 ? 'disabled' : '' }}>
                {% if bookshop_stock_movement_form.book_id|default(0) == 0 %}
                  <option value="">Selecione primeiro o livro</option>
                {% elseif bookshop_stock_movement_lot_options|default([])|length == 0 %}
                  <option value="">Nenhum lote disponível</option>
                {% else %}
                  <option value="">Selecione o lote</option>
                  {% for lot in bookshop_stock_movement_lot_options|default([]) %}
                    <option value="{{ lot.id }}" {{ bookshop_stock_movement_form.stock_lot_id|default(0) == lot.id ? 'selected' : '' }}>{{ lot.label }}</option>
                  {% endfor %}
                {% endif %}
              </select>
            </div>
          {% endif %}

          {% if bookshop_stock_movement_mode != 'adjustment' %}
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="occurred_at">Data e hora</label>
              <input class="nc-admin-form-input" id="occurred_at" name="occurred_at" type="datetime-local" required value="{{ bookshop_stock_movement_form.occurred_at|default('') ? bookshop_stock_movement_form.occurred_at|replace({' ': 'T'})|slice(0, 16) : '' }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="movement_type">{{ bookshop_stock_movement_type_label|default('Tipo da movimentação')|capitalize }}</label>
              <select class="nc-admin-form-input" id="movement_type" name="movement_type" required data-bookshop-movement-type-select>
                {% for value, label in bookshop_stock_movement_type_options|default({}) %}
                  <option value="{{ value }}" {{ bookshop_stock_movement_form.movement_type|default('') == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
              </select>
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="quantity">Quantidade</label>
              <input class="nc-admin-form-input" id="quantity" name="quantity" type="number" min="1" step="1" required value="{{ bookshop_stock_movement_form.quantity|default(1) }}" data-bookshop-movement-quantity-input>
            </div>
          {% endif %}
        </div>

        <div class="nc-admin-form-grid nc-admin-form-grid-bookshop-stock-movement-meta{% if bookshop_stock_movement_mode == 'adjustment' %} nc-admin-form-grid-bookshop-stock-movement-meta-adjustment{% endif %}">
          {% if bookshop_stock_movement_mode == 'adjustment' %}
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="occurred_at">Data e hora</label>
              <input class="nc-admin-form-input" id="occurred_at" name="occurred_at" type="datetime-local" required value="{{ bookshop_stock_movement_form.occurred_at|default('') ? bookshop_stock_movement_form.occurred_at|replace({' ': 'T'})|slice(0, 16) : '' }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="movement_type">{{ bookshop_stock_movement_type_label|default('Tipo da movimentação')|capitalize }}</label>
              <select class="nc-admin-form-input" id="movement_type" name="movement_type" required data-bookshop-movement-type-select>
                {% for value, label in bookshop_stock_movement_type_options|default({}) %}
                  <option value="{{ value }}" {{ bookshop_stock_movement_form.movement_type|default('') == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
              </select>
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="quantity">Quantidade</label>
              <input class="nc-admin-form-input" id="quantity" name="quantity" type="number" min="1" step="1" required value="{{ bookshop_stock_movement_form.quantity|default(1) }}" data-bookshop-movement-quantity-input>
            </div>
          {% endif %}

          <div class="nc-admin-form-field" data-bookshop-movement-cost-field>
            <label class="nc-admin-form-label" for="unit_cost">Custo unitário</label>
            <input class="nc-admin-form-input" id="unit_cost" name="unit_cost" type="text" inputmode="decimal" placeholder="Ex: 18,90" value="{{ bookshop_stock_movement_form.unit_cost|default('') }}" data-bookshop-movement-cost-input {{ bookshop_stock_movement_cost_required|default(false) ? 'required' : '' }} {{ bookshop_stock_movement_cost_hidden|default(false) ? 'disabled' : '' }}>
          </div>

          <div class="nc-admin-form-field">
            <label class="nc-admin-form-label" for="sale_price">Preço de venda do lote</label>
            <input class="nc-admin-form-input" id="sale_price" name="sale_price" type="text" inputmode="decimal" placeholder="Ex: 55,00" value="{{ bookshop_stock_movement_form.sale_price|default('') }}">
          </div>

          <div class="nc-admin-form-field nc-admin-form-field-full">
            <label class="nc-admin-form-label" for="notes">Observações</label>
            <textarea class="nc-admin-form-input" id="notes" name="notes" rows="4" placeholder="Ex: reposição recebida da distribuidora, ajuste após conferência física, exemplar avariado...">{{ bookshop_stock_movement_form.notes|default('') }}</textarea>
          </div>
        </div>

        <div class="nc-actions">
          <button class="nc-btn nc-btn-primary" type="submit">{{ bookshop_stock_movement_mode == 'adjustment' ? 'Registrar ajuste' : 'Registrar entrada' }}</button>
          <a class="nc-btn nc-btn-secondary" href="/painel/livraria/movimentacoes">Cancelar</a>
        </div>
      </form>
    </article>
  </section>

  <script>
    (function () {
      var form = document.querySelector('[data-bookshop-stock-movement-form]');
      if (!form) {
        return;
      }

      var optionsPayload = form.getAttribute('data-bookshop-options') || '[]';
      var options;
      var summaryScope = form.closest('.nc-admin-form-card') || document;
      var bookSelect = form.querySelector('[data-bookshop-movement-book-select]');
      var lotSelect = form.querySelector('[data-bookshop-movement-lot-select]');
      var typeSelect = form.querySelector('[data-bookshop-movement-type-select]');
      var quantityInput = form.querySelector('[data-bookshop-movement-quantity-input]');
      var costInput = form.querySelector('[data-bookshop-movement-cost-input]');
      var saleInput = form.querySelector('#sale_price');
      var titleOutput = summaryScope.querySelector('[data-bookshop-movement-summary-title]');
      var stockOutput = summaryScope.querySelector('[data-bookshop-movement-summary-stock]');
      var deltaOutput = summaryScope.querySelector('[data-bookshop-movement-summary-delta]');
      var projectedOutput = summaryScope.querySelector('[data-bookshop-movement-summary-projected]');
      var formMode = form.dataset.bookshopStockMovementMode || 'entry';

      try {
        options = JSON.parse(optionsPayload);
      } catch (error) {
        options = [];
      }

      options = Array.isArray(options) ? options.map(function (option) {
        option.stock_lots = Array.isArray(option.stock_lots) ? option.stock_lots : [];
        return option;
      }) : [];

      var optionsById = {};
      options.forEach(function (option) {
        optionsById[String(option.id || '')] = option;
      });

      if (!bookSelect || !typeSelect || !quantityInput || !titleOutput || !stockOutput || !deltaOutput || !projectedOutput) {
        return;
      }

      function resolveSelectedOption() {
        if (!bookSelect.value) {
          return null;
        }

        return bookSelect.options[bookSelect.selectedIndex] || null;
      }

      function resolveSelectedBookRecord() {
        if (!bookSelect.value) {
          return null;
        }

        return optionsById[String(bookSelect.value || '')] || null;
      }

      function resolveSelectedLotOption() {
        if (!lotSelect || !lotSelect.value) {
          return null;
        }

        return lotSelect.options[lotSelect.selectedIndex] || null;
      }

      function resolveDelta(quantity, movementType) {
        if (movementType === 'adjustment_remove' || movementType === 'loss') {
          return quantity * -1;
        }

        return quantity;
      }

      function buildLotOptions(bookOption, selectedLotValue) {
        var placeholder;

        if (!lotSelect) {
          return;
        }

        lotSelect.innerHTML = '';
        placeholder = document.createElement('option');
        placeholder.value = '';

        if (!bookOption) {
          placeholder.textContent = 'Selecione primeiro o livro';
          lotSelect.appendChild(placeholder);
          lotSelect.disabled = true;
          lotSelect.value = '';
          return;
        }

        if (!Array.isArray(bookOption.stock_lots) || bookOption.stock_lots.length === 0) {
          placeholder.textContent = 'Nenhum lote disponível';
          lotSelect.appendChild(placeholder);
          lotSelect.disabled = true;
          lotSelect.value = '';
          return;
        }

        placeholder.textContent = 'Selecione o lote';
        lotSelect.appendChild(placeholder);
        lotSelect.disabled = false;

        bookOption.stock_lots.forEach(function (lot) {
          var element = document.createElement('option');
          var normalizedLotId = String(lot.id || '');

          element.value = normalizedLotId;
          element.textContent = lot.label || (lot.lot_code || 'Lote');
          element.dataset.stockQuantity = String(lot.quantity_available || 0);
          element.dataset.salePriceLabel = String(lot.unit_sale_price_label || 'R$ 0,00');
          element.dataset.costLabel = String(lot.unit_cost_label || '-');
          element.dataset.occurredAtLabel = String(lot.occurred_at_label || '');
          element.dataset.unitCost = String(lot.unit_cost || '');
          element.dataset.unitSalePrice = String(lot.unit_sale_price || '');

          if (selectedLotValue && normalizedLotId === String(selectedLotValue)) {
            element.selected = true;
          }

          lotSelect.appendChild(element);
        });

        if (!lotSelect.value && bookOption.stock_lots.length === 1) {
          lotSelect.value = String(bookOption.stock_lots[0].id || '');
        }
      }

      function refreshLotFieldState(preserveSelectedLot) {
        var bookOption;
        var movementType;
        var stockLots;
        var selectedLotValue;

        if (!lotSelect || formMode !== 'adjustment') {
          return;
        }

        bookOption = resolveSelectedBookRecord();
        movementType = typeSelect.value || '';
        stockLots = bookOption && Array.isArray(bookOption.stock_lots) ? bookOption.stock_lots : [];
        selectedLotValue = preserveSelectedLot
          ? (lotSelect.value || lotSelect.getAttribute('data-selected-lot') || '')
          : '';

        buildLotOptions(bookOption, selectedLotValue);
        lotSelect.required = stockLots.length > 0 && (
          movementType === 'adjustment_remove'
          || movementType === 'loss'
          || (movementType === 'adjustment_add' && stockLots.length > 1)
        );
        lotSelect.setAttribute('data-selected-lot', lotSelect.value || '');
      }

      function refreshCostFieldState() {
        if (!costInput) {
          return;
        }

        var movementType = typeSelect.value || '';
        var shouldHideCost = formMode === 'entry' && movementType === 'donation';
        var shouldRequireCost = formMode === 'entry' && movementType === 'entry';

        costInput.disabled = shouldHideCost;
        costInput.required = shouldRequireCost;

        if (shouldHideCost) {
          costInput.value = '';
        }
      }

      function formatMoneyValue(rawValue) {
        if (!rawValue) {
          return '';
        }
        if (String(rawValue).indexOf(',') >= 0) {
          return String(rawValue);
        }
        return String(rawValue).replace('.', ',');
      }

      function refreshLotDependentFields() {
        if (formMode !== 'adjustment') {
          return;
        }

        var movementType = typeSelect.value || '';
        var lotOption = resolveSelectedLotOption();
        var shouldLockValues = movementType === 'adjustment_remove' || movementType === 'loss';

        if (costInput) {
          costInput.readOnly = shouldLockValues;
        }

        if (saleInput) {
          saleInput.readOnly = shouldLockValues;
        }

        if (!lotOption) {
          return;
        }

        if (costInput && !costInput.value) {
          costInput.value = formatMoneyValue(lotOption.dataset.unitCost || '');
        }

        if (saleInput && !saleInput.value) {
          saleInput.value = formatMoneyValue(lotOption.dataset.unitSalePrice || '');
        }
      }

      function refreshSummary() {
        var option = resolveSelectedOption();
        var quantity = parseInt(quantityInput.value || '0', 10);
        var safeQuantity = Number.isFinite(quantity) && quantity > 0 ? quantity : 0;
        var movementType = typeSelect.value || '';
        var delta = resolveDelta(safeQuantity, movementType);

        if (!option) {
          titleOutput.textContent = 'Nenhum livro';
          stockOutput.textContent = '0';
          deltaOutput.textContent = '+0';
          projectedOutput.textContent = '0';
          return;
        }

        var currentStock = parseInt(option.dataset.stock || '0', 10);
        var safeCurrentStock = Number.isFinite(currentStock) ? currentStock : 0;
        var projectedStock = safeCurrentStock + delta;
        var title = option.dataset.title || option.textContent || 'Livro';

        titleOutput.textContent = title;
        stockOutput.textContent = String(safeCurrentStock);
        deltaOutput.textContent = (delta >= 0 ? '+' : '') + String(delta);
        projectedOutput.textContent = String(projectedStock);
      }

      bookSelect.addEventListener('change', function () {
        refreshLotFieldState(false);
        refreshLotDependentFields();
        refreshSummary();
      });
      if (lotSelect) {
        lotSelect.addEventListener('change', function () {
          lotSelect.setAttribute('data-selected-lot', lotSelect.value || '');
          refreshLotDependentFields();
        });
      }
      typeSelect.addEventListener('change', function () {
        refreshLotFieldState(true);
        refreshCostFieldState();
        refreshLotDependentFields();
        refreshSummary();
      });
      quantityInput.addEventListener('input', refreshSummary);
      refreshLotFieldState(true);
      refreshCostFieldState();
      refreshLotDependentFields();
      refreshSummary();
    })();
  </script>
{% endblock %}
