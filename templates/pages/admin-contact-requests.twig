{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = 'Solicitações de contato' %}
{% set dashboard_page_lead = 'Acompanhe protocolos, IDs, status de atendimento e histórico dos contatos recebidos pelo site.' %}

{% block admin_content %}
  <section class="nc-section" aria-label="Solicitações de contato" data-aos="fade-up" data-aos-delay="0">
    {% set toast_message = '' %}
    {% set toast_tone = 'error' %}
    {% if admin_contact_requests_status|default('') == 'status-updated' %}
      {% set toast_message = admin_contact_requests_error|default('Status da solicitação atualizado com sucesso.') %}
      {% set toast_tone = 'success' %}
    {% elseif admin_contact_requests_status|default('') == 'update-error' %}
      {% set toast_message = admin_contact_requests_error|default('Não foi possível atualizar o status da solicitação.') %}
      {% set toast_tone = 'error' %}
    {% elseif admin_contact_requests_status|default('') == 'load-error' %}
      {% set toast_message = admin_contact_requests_error|default('Não foi possível carregar as solicitações de contato no momento.') %}
      {% set toast_tone = 'error' %}
    {% endif %}

    {% include 'components/admin-toast.twig' with {
      message: toast_message,
      tone: toast_tone
    } %}

    <div class="nc-actions nc-admin-toolbar" data-aos="fade-up" data-aos-delay="70">
      <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel">Voltar ao painel</a>
    </div>

    {% set pagination = admin_contact_requests_pagination|default({}) %}
    {% set sort_links = admin_contact_requests_sort_links|default({}) %}
    {% set search_term = admin_contact_requests_search|default('') %}
    {% set status_filter = admin_contact_requests_filter_status|default('all') %}
    {% set status_options = admin_contact_requests_status_options|default([]) %}
    {% set current_url = admin_contact_requests_current_url|default('/painel/institucional/solicitacoes-contato') %}
    {% set has_active_filters = search_term != '' or status_filter != 'all' %}

    <form class="nc-admin-table-search" method="get" action="/painel/institucional/solicitacoes-contato" data-aos="fade-up" data-aos-delay="80">
      <label for="nc-contact-requests-search">Buscar solicitações</label>
      <div class="nc-admin-table-search-controls">
        <input id="nc-contact-requests-search" name="q" type="search" value="{{ search_term }}" placeholder="Protocolo, ID, nome, e-mail, assunto, mensagem...">
        <select name="status" aria-label="Filtrar por status de atendimento">
          {% for option in status_options %}
            <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.label }}</option>
          {% endfor %}
        </select>
        <input type="hidden" name="sort" value="{{ pagination.sort|default('submitted_at') }}">
        <input type="hidden" name="dir" value="{{ pagination.dir|default('desc') }}">
        <input type="hidden" name="per_page" value="{{ pagination.page_size|default(20) }}">
        <button class="nc-btn nc-btn-secondary" type="submit">Buscar</button>
        {% if has_active_filters %}
          <a class="nc-btn nc-btn-secondary" href="/painel/institucional/solicitacoes-contato">Limpar filtros</a>
        {% endif %}
      </div>
    </form>

    {% if admin_contact_requests|length == 0 %}
      <p>{{ has_active_filters ? 'Nenhuma solicitação encontrada para os filtros informados.' : 'Nenhuma solicitação registrada até o momento.' }}</p>
    {% else %}
      <div class="nc-admin-table-toolbar" data-aos="fade-up" data-aos-delay="90">
        <p class="nc-admin-table-counter">
          Mostrando {{ pagination.start_item }}-{{ pagination.end_item }} de {{ pagination.total_items }} registros
        </p>

        <form class="nc-admin-table-page-size" method="get" action="/painel/institucional/solicitacoes-contato">
          <label for="nc-contact-requests-per-page">Registros por página</label>
          <select id="nc-contact-requests-per-page" name="per_page" onchange="this.form.submit()">
            {% for option in pagination.page_size_options %}
              <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.label|default(option.value) }}</option>
            {% endfor %}
          </select>
          <input type="hidden" name="sort" value="{{ pagination.sort|default('submitted_at') }}">
          <input type="hidden" name="dir" value="{{ pagination.dir|default('desc') }}">
          <input type="hidden" name="status" value="{{ status_filter }}">
          <input type="hidden" name="q" value="{{ search_term }}">
          <noscript>
            <button class="nc-btn nc-btn-secondary" type="submit">Aplicar</button>
          </noscript>
        </form>
      </div>

      <div class="nc-admin-table-wrap" data-aos="fade-up" data-aos-delay="100">
        <table class="nc-admin-table">
          <thead>
            <tr>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.submitted_at.active %} is-active{% endif %}" href="{{ sort_links.submitted_at.url|default('#') }}">Data/Hora <span aria-hidden="true">{{ sort_links.submitted_at.indicator|default('↕') }}</span></a>
              </th>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.request_protocol.active %} is-active{% endif %}" href="{{ sort_links.request_protocol.url|default('#') }}">Protocolo <span aria-hidden="true">{{ sort_links.request_protocol.indicator|default('↕') }}</span></a>
              </th>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.name.active %} is-active{% endif %}" href="{{ sort_links.name.url|default('#') }}">Nome <span aria-hidden="true">{{ sort_links.name.indicator|default('↕') }}</span></a>
              </th>
              <th>Segmento</th>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.subject.active %} is-active{% endif %}" href="{{ sort_links.subject.url|default('#') }}">Assunto <span aria-hidden="true">{{ sort_links.subject.indicator|default('↕') }}</span></a>
              </th>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.status.active %} is-active{% endif %}" href="{{ sort_links.status.url|default('#') }}">Status <span aria-hidden="true">{{ sort_links.status.indicator|default('↕') }}</span></a>
              </th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            {% for request in admin_contact_requests %}
              <tr>
                <td data-label="Data/Hora">{{ request.submitted_at_label|default('-') }}</td>
                <td data-label="Protocolo">
                  <strong>{{ request.request_protocol|default('-') }}</strong>
                </td>
                <td data-label="Nome e E-mail">
                  <div>{{ request.name|default('-') }}</div>
                  {% if request.email|default('') != '' %}
                    <small class="nc-admin-user-email-inline nc-admin-email-inline">
                      <a class="nc-link" href="mailto:{{ request.email }}">{{ request.email }}</a>
                    </small>
                  {% else %}
                    <small class="nc-admin-user-email-inline nc-admin-email-inline">-</small>
                  {% endif %}
                </td>
                <td data-label="Segmento">{{ request.segment|default('-') != '' ? request.segment : '-' }}</td>
                <td data-label="Assunto">{{ request.subject|default('-') }}</td>
                <td data-label="Status" class="nc-admin-contact-status-cell">
                  <span class="nc-admin-featured-flag {{ request.status_badge_modifier|default('is-off') }}">{{ request.status_label|default('Novo') }}</span>
                  <small class="nc-admin-user-email-inline nc-admin-contact-status-meta">
                    Atualizado: {{ request.status_updated_at_label|default('-') }}{% if request.status_updated_by_label|default('-') != '-' %} • {{ request.status_updated_by_label }}{% endif %}
                  </small>

                  <form class="nc-admin-inline-form nc-admin-contact-status-form" method="post" action="/painel/institucional/solicitacoes-contato">
          {% include 'components/csrf-field.twig' %}
                    <input type="hidden" name="request_id" value="{{ request.id }}">
                    <input type="hidden" name="return_to" value="{{ current_url }}">
                    <select class="nc-admin-inline-select" name="status" aria-label="Atualizar status da solicitação {{ request.request_protocol|default(request.id) }}">
                      {% for option in status_options %}
                        {% if option.value != 'all' %}
                          <option value="{{ option.value }}"{% if request.status|default('novo') == option.value %} selected{% endif %}>{{ option.label }}</option>
                        {% endif %}
                      {% endfor %}
                    </select>
                    <input class="nc-admin-contact-note-input" type="text" name="note" maxlength="200" placeholder="Observação opcional">
                    <button class="nc-btn nc-admin-action-create" type="submit">Salvar</button>
                  </form>

                  {% if request.events|default([])|length > 0 %}
                    <details class="nc-admin-contact-history">
                      <summary>Histórico ({{ request.events|length }})</summary>
                      <ul class="nc-admin-contact-history-list">
                        {% for event in request.events %}
                          <li>
                            <strong>{{ event.next_status_label|default('-') }}</strong>
                            {% if event.previous_status_label|default('') != '' and event.previous_status_label != '-' and event.previous_status_label != event.next_status_label %}
                              <span> (de {{ event.previous_status_label }})</span>
                            {% endif %}
                            <span> • {{ event.created_at_label|default('-') }}</span>
                            {% if event.actor_label|default('-') != '-' %}
                              <span> • {{ event.actor_label }}</span>
                            {% endif %}
                            {% if event.note|default('') != '' %}
                              <p>{{ event.note }}</p>
                            {% endif %}
                          </li>
                        {% endfor %}
                      </ul>
                    </details>
                  {% endif %}
                </td>
                <td class="nc-admin-table-actions" data-label="Ações">
                  <button
                    class="nc-btn nc-btn-secondary nc-admin-action-open nc-admin-contact-view-toggle"
                    type="button"
                    data-contact-target="nc-contact-summary-{{ request.id }}"
                    aria-expanded="false"
                    aria-controls="nc-contact-summary-{{ request.id }}">
                    Visualizar
                  </button>
                </td>
              </tr>
              <tr id="nc-contact-summary-{{ request.id }}" class="nc-admin-contact-summary-row" hidden>
                <td data-label="Resumo" colspan="7">
                  <article class="nc-admin-contact-summary-card">
                    <h4 class="nc-admin-contact-summary-title">Resumo da solicitação</h4>
                    <dl class="nc-admin-contact-summary-grid">
                      <div class="nc-admin-contact-summary-item">
                        <dt>Protocolo</dt>
                        <dd>{{ request.request_protocol|default('-') }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item">
                        <dt>ID interno</dt>
                        <dd>{{ request.request_id|default('-') }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item">
                        <dt>Data/Hora</dt>
                        <dd>{{ request.submitted_at_label|default('-') }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item">
                        <dt>Status</dt>
                        <dd>{{ request.status_label|default('Novo') }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item">
                        <dt>Nome</dt>
                        <dd>{{ request.name|default('-') }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item">
                        <dt>E-mail</dt>
                        <dd>
                          {% if request.email|default('') != '' %}
                            <a class="nc-link" href="mailto:{{ request.email }}">{{ request.email }}</a>
                          {% else %}
                            -
                          {% endif %}
                        </dd>
                      </div>
                      <div class="nc-admin-contact-summary-item">
                        <dt>Segmento</dt>
                        <dd>{{ request.segment|default('-') != '' ? request.segment : '-' }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item">
                        <dt>Assunto</dt>
                        <dd>{{ request.subject|default('-') }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item nc-admin-contact-summary-message">
                        <dt>Mensagem</dt>
                        <dd>{{ request.message|default('-')|nl2br }}</dd>
                      </div>
                      <div class="nc-admin-contact-summary-item nc-admin-contact-summary-origin">
                        <dt>Origem</dt>
                        <dd>
                          {% if request.origin_url|default('') != '' %}
                            <a class="nc-link" href="{{ request.origin_url }}" target="_blank" rel="noopener">{{ request.origin_url }}</a>
                          {% else %}
                            -
                          {% endif %}
                        </dd>
                      </div>
                    </dl>
                  </article>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if pagination.total_pages > 1 %}
        <nav class="nc-pagination" aria-label="Paginação de solicitações de contato" data-aos="fade-up" data-aos-delay="110">
          {% if pagination.previous_url %}
            <a class="nc-link nc-pagination-link" href="{{ pagination.previous_url }}">Anterior</a>
          {% endif %}

          {% for link in pagination.links %}
            <a class="nc-link nc-pagination-link{{ link.active ? ' is-active' : '' }}" href="{{ link.url }}">{{ link.number }}</a>
          {% endfor %}

          {% if pagination.next_url %}
            <a class="nc-link nc-pagination-link" href="{{ pagination.next_url }}">Próxima</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endif %}
  </section>

  <script>
    (function () {
      var toggleButtons = document.querySelectorAll('.nc-admin-contact-view-toggle');
      if (!toggleButtons.length) {
        return;
      }

      function getTargetRow(button) {
        var targetId = button.getAttribute('data-contact-target');
        if (!targetId) {
          return null;
        }

        return document.getElementById(targetId);
      }

      function setExpanded(button, expanded) {
        var targetRow = getTargetRow(button);
        if (!targetRow) {
          return;
        }

        targetRow.hidden = !expanded;
        targetRow.style.display = expanded ? '' : 'none';
        button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        button.classList.toggle('is-open', expanded);
        button.textContent = expanded ? 'Fechar' : 'Visualizar';
      }

      function closeOtherRows(activeButton) {
        toggleButtons.forEach(function (button) {
          if (button !== activeButton) {
            setExpanded(button, false);
          }
        });
      }

      toggleButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          var isExpanded = button.getAttribute('aria-expanded') === 'true';
          if (!isExpanded) {
            closeOtherRows(button);
          }

          setExpanded(button, !isExpanded);
        });
      });
    })();
  </script>
{% endblock %}
