{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    {% set founder = homeContent.aboutPages.fundador|default({}) %}

    <section class="nc-section nc-home-hero nc-about-hero-video has-background-image" aria-label="Vídeo institucional da NatalCode">
      <div class="nc-home-hero-media" aria-hidden="true">
        <video
          class="nc-home-hero-media-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
          <source src="/assets/videos/341476.mp4" type="video/mp4">
        </video>
      </div>
      <div class="nc-home-hero-overlay" aria-hidden="true"></div>

      <div class="nc-hero-grid is-single-column">
        <div class="nc-hero-copy-stack" data-aos="fade-up" data-aos-delay="80">
          <p class="nc-section-kicker">Quem Somos</p>
          <h1 class="nc-title">Estratégia, design e engenharia para crescimento digital</h1>
          <p class="nc-hero-tagline">Projetos sob medida com foco em conversão e evolução contínua</p>
          <p class="nc-lead">Da descoberta à publicação, a NatalCode integra posicionamento, tecnologia e acompanhamento pós-lançamento para gerar resultado mensurável com previsibilidade.</p>

          <div class="nc-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="140">
            <a class="nc-btn nc-btn-primary" href="/portfolio">Ver portfólio</a>
            <a class="nc-btn nc-btn-secondary" href="/contato">Solicitar orçamento</a>
          </div>
        </div>
      </div>
    </section>

    <section class="nc-section nc-about-overview" aria-label="Posicionamento da NatalCode" data-aos="fade-up" data-aos-delay="20">
      {% include 'components/section-header.twig' with {
        kicker: 'Quem Somos',
        title: 'Agência digital orientada a resultado',
        lead: 'A NatalCode combina estratégia, design e engenharia para construir sites, landing pages e produtos digitais com foco em conversão, performance e evolução contínua. Atuamos do briefing à publicação, com método claro, entregas previsíveis e acompanhamento pós-lançamento.'
      } %}

      <div class="nc-actions nc-tonal-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="140">
        <a class="nc-btn nc-btn-primary" href="/portfolio">Ver portfólio</a>
        <a class="nc-btn nc-btn-secondary" href="/contato">Solicitar orçamento</a>
      </div>
    </section>

    <section class="nc-section nc-about-overview" aria-label="Soluções da NatalCode" data-aos="fade-up" data-aos-delay="30">
      {% include 'components/section-header.twig' with {
        kicker: 'Soluções',
        title: 'O que entregamos para o seu negócio',
        lead: 'Estruturamos presença digital profissional para gerar mais contatos qualificados e melhorar a operação comercial.'
      } %}

      <div class="nc-feature-grid nc-tonal-feature-grid">
        {% include 'components/feature-card.twig' with {
          title: 'Landing Pages',
          description: 'Páginas de campanha com foco em conversão, copy estratégica e CTA claro.',
          href: '/estudos/esde',
          link_label: 'Ver serviço',
          delay: 120
        } %}

        {% include 'components/feature-card.twig' with {
          title: 'Sites Institucionais',
          description: 'Sites completos para posicionamento, autoridade da marca e geração de demanda.',
          href: '/estudos/eade',
          link_label: 'Ver serviço',
          delay: 170
        } %}

        {% include 'components/feature-card.twig' with {
          title: 'SEO e Evolução',
          description: 'Ajustes técnicos e de conteúdo para melhorar visibilidade orgânica e performance.',
          href: '/estudos/palestras',
          link_label: 'Ver serviço',
          delay: 220
        } %}
      </div>
    </section>

    <section class="nc-section" aria-label="Método de trabalho da NatalCode" data-aos="fade-up" data-aos-delay="40">
      {% include 'components/section-header.twig' with {
        kicker: 'Método',
        title: 'Como trabalhamos em cada projeto',
        lead: 'Processo objetivo para reduzir retrabalho e acelerar a entrega com qualidade.'
      } %}

      <div class="nc-feature-grid nc-tonal-feature-grid">
        {% include 'components/feature-card.twig' with {
          title: '1. Diagnóstico e briefing',
          description: 'Entendimento de público, oferta e objetivos comerciais para definir escopo certo.',
          delay: 120
        } %}

        {% include 'components/feature-card.twig' with {
          title: '2. Execução e validação',
          description: 'Sprints curtas com checkpoints, revisão de conteúdo e aprovação das entregas.',
          delay: 170
        } %}

        {% include 'components/feature-card.twig' with {
          title: '3. Publicação e evolução',
          description: 'Go-live assistido, mensuração inicial e plano de melhorias contínuas.',
          delay: 220
        } %}
      </div>
    </section>

    <section class="nc-section nc-about-founder-overview" aria-label="Governança da NatalCode" data-aos="fade-up" data-aos-delay="50">
      {% include 'components/section-header.twig' with {
        kicker: founder.kicker|default('Governança'),
        title: founder.title|default('Direção da NatalCode'),
        lead: founder.lead|default('Conheça a visão que orienta nosso posicionamento e a execução dos projetos digitais.')
      } %}

      <div class="nc-actions nc-tonal-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="140">
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/fundador">Conhecer governança</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/base-de-conhecimento">Base de conhecimento</a>
      </div>
    </section>

    {% include 'home/final-cta.twig' %}
  </main>
{% endblock %}
