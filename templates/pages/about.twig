{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    {% set institutional = site.institutional|default({}) %}
    {% set founder = homeContent.aboutPages.fundador|default({}) %}

    <section class="nc-section" aria-label="Detalhes institucionais">
      {% include 'components/section-header.twig' with {
        kicker: 'Quem Somos',
        title: 'Conheça nossa identidade',
        lead: 'Acesse conteúdos específicos sobre missão, valores, história, fundador e estatuto do CEDE.'
      } %}
      <div class="nc-actions nc-tonal-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="120">
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/missao">Missão</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/valores">Valores</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/historia">História</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/fundador">Fundador</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/estatuto">Estatuto</a>
      </div>
    </section>

    <section class="nc-section" aria-label="Fundador do CEDE" data-aos="fade-up" data-aos-delay="30">
      {% include 'components/section-header.twig' with {
        kicker: founder.kicker|default('Quem Somos'),
        title: founder.title|default('Nosso Fundador'),
        lead: founder.lead|default('Conheça a origem humana e espiritual que ajudou a dar início ao CEDE.')
      } %}

      <div class="nc-actions nc-tonal-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="140">
        <a class="nc-btn nc-btn-primary" href="/quem-somos/fundador">Abrir página do fundador</a>
      </div>
    </section>

    <section class="nc-section" aria-label="Natureza jurídica e sede" data-aos="fade-up" data-aos-delay="20">
      {% include 'components/section-header.twig' with {
        kicker: 'Institucional',
        title: 'Natureza jurídica e sede',
        lead: 'Base estatutária e dados institucionais do CEDE.'
      } %}

      <div class="nc-about-legal-copy" data-aos="fade-up" data-aos-delay="120">
        <h3>Constituição do CEDE</h3>
        <p>{{ institutional.statuteExcerpt|default('O Centro de Estudos da Doutrina Espírita - CEDE, fundado em 09 de janeiro de 2001, é uma associação civil de caráter religioso, filosófico, científico, cultural e filantrópico, sem fins lucrativos, com sede e foro na cidade de Parnamirim/RN, localizada à Rua Frejó, nº 44, bairro Nova Parnamirim.') }}</p>
      </div>

      <div class="nc-actions nc-tonal-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="160">
        <a class="nc-btn nc-btn-primary" href="/quem-somos/estatuto">Ler estatuto completo</a>
      </div>
    </section>

    <section class="nc-section nc-about-management-preview" aria-label="Gestão CEDE" data-aos="fade-up" data-aos-delay="40">
      {% include 'components/section-header.twig' with {
        kicker: 'Gestão CEDE',
        title: 'Diretoria e funções institucionais',
        lead: 'Conheça a gestão atual do CEDE: acesse a página dedicada e descubra quem são os responsáveis e as atribuições que sustentam a organização e o funcionamento da instituição.'
      } %}

      <div class="nc-actions nc-tonal-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="140">
        <a class="nc-btn nc-btn-primary" href="/quem-somos/gestao-cede">Abrir Gestão CEDE</a>
      </div>
    </section>

    {% include 'home/final-cta.twig' %}
  </main>
{% endblock %}
