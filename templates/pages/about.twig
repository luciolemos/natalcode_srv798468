{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    <section class="nc-section" aria-label="Detalhes institucionais">
      {% include 'components/section-header.twig' with {
        kicker: 'Quem Somos',
        title: 'Conheça nossa identidade',
        lead: 'Acesse conteúdos específicos sobre missão, valores, história e simbologia da marca do CEDE.'
      } %}
      <div class="nc-actions" data-aos="fade-up" data-aos-delay="120">
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/missao">Missão</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/valores">Valores</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/historia">História</a>
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/nossa-marca">Nossa Marca</a>
      </div>
    </section>

    <section class="nc-section" aria-label="Gestão CEDE" data-aos="fade-up" data-aos-delay="40">
      {% include 'components/section-header.twig' with {
        kicker: 'Gestão CEDE',
        title: 'Diretoria e funções institucionais',
        lead: 'Acesse a página dedicada com os membros da gestão atual e as atribuições institucionais de cada função.'
      } %}

      <div class="nc-actions" data-aos="fade-up" data-aos-delay="140">
        <a class="nc-btn nc-btn-secondary" href="/quem-somos/gestao-cede">Abrir Gestão CEDE</a>
      </div>
    </section>

    {% include 'home/final-cta.twig' %}
  </main>
{% endblock %}
