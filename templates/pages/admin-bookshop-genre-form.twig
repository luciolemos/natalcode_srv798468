{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = bookshop_genre_form_is_edit ? 'Editar gênero literário da livraria' : 'Novo gênero literário da livraria' %}
{% set dashboard_page_lead = 'Cadastre gêneros literários para classificar as obras da livraria em paralelo às categorias doutrinárias de estudo.' %}

{% block admin_content %}
  <section class="nc-section" aria-label="Formulário de gênero literário da livraria" data-aos="fade-up" data-aos-delay="0">
    {% if bookshop_genre_form_errors|length > 0 %}
      <article class="nc-admin-form-errors" role="alert">
        <strong>Corrija os campos abaixo:</strong>
        <ul>
          {% for error in bookshop_genre_form_errors %}
            <li>{{ error }}</li>
          {% endfor %}
        </ul>
      </article>
    {% endif %}

    <div class="nc-actions nc-bookshop-toolbar" data-aos="fade-up" data-aos-delay="60">
      <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel">Voltar ao painel</a>
      <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel/livraria/generos">Voltar aos gêneros literários</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/categorias">Categorias doutrinárias</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/acervo">Acervo</a>
    </div>

    <article class="nc-card nc-admin-form-card">
      <form class="nc-admin-form" method="post" action="{{ bookshop_genre_form_is_edit ? '/painel/livraria/generos/' ~ bookshop_genre_id ~ '/editar' : '/painel/livraria/generos/novo' }}">
          {% include 'components/csrf-field.twig' %}
        <div class="nc-admin-form-grid nc-admin-form-grid-triplet">
          <div class="nc-admin-form-field">
            <label class="nc-admin-form-label" for="name">Nome do gênero literário</label>
            <input class="nc-admin-form-input" id="name" name="name" type="text" required placeholder="Ex: Romance" value="{{ bookshop_genre_form.name|default('') }}">
          </div>

          <div class="nc-admin-form-field">
            <label class="nc-admin-form-label" for="slug">Slug</label>
            <input class="nc-admin-form-input" id="slug" name="slug" type="text" required placeholder="Ex: romance" value="{{ bookshop_genre_form.slug|default('') }}">
          </div>

          <div class="nc-admin-form-field">
            <label class="nc-admin-form-label" for="is_active">Status</label>
            <select class="nc-admin-form-input" id="is_active" name="is_active" required>
              <option value="" {% if bookshop_genre_form.is_active|default('') == '' %}selected{% endif %} disabled>Selecione</option>
              <option value="1" {{ bookshop_genre_form.is_active|default('1') == '1' ? 'selected' : '' }}>Ativo</option>
              <option value="0" {{ bookshop_genre_form.is_active|default('1') == '0' ? 'selected' : '' }}>Inativo</option>
            </select>
          </div>

        </div>

        <div class="nc-admin-form-grid nc-admin-form-grid-genre-color">
          <div class="nc-admin-form-field">
            <label class="nc-admin-form-label" for="color">Cor do gênero (hex)</label>
            <div class="nc-admin-form-color-field">
              <input class="nc-admin-form-input" id="color" name="color" type="text" placeholder="Ex: #2563eb" value="{{ bookshop_genre_form.color|default('') }}">
              <input class="nc-admin-form-input nc-admin-form-color-input" id="color_picker" type="color" value="{{ bookshop_genre_form.color|default('#2563eb') }}">
            </div>
            <p class="nc-admin-statute-meta">Opcional. Use para identificar o gênero na interface.</p>
          </div>
        </div>

        <div class="nc-admin-form-field nc-admin-form-field-full">
          <label class="nc-admin-form-label" for="description">Descrição</label>
          <textarea class="nc-admin-form-input" id="description" name="description" rows="4" placeholder="Explique o tipo de obras que pertencem a este gênero literário.">{{ bookshop_genre_form.description|default('') }}</textarea>
        </div>

        <div class="nc-actions nc-admin-form-actions" data-aos="fade-up" data-aos-delay="120">
          <button class="nc-btn nc-btn-primary nc-admin-action-create" type="submit">{{ bookshop_genre_form_is_edit ? 'Salvar alterações' : 'Criar gênero literário' }}</button>
          <a class="nc-btn nc-btn-secondary" href="/painel/livraria/generos">Cancelar</a>
        </div>
      </form>
    </article>

    <script>
      (function () {
        var textInput = document.getElementById('color');
        var picker = document.getElementById('color_picker');

        if (!textInput || !picker) {
          return;
        }

        function normalize(value) {
          return String(value || '').trim();
        }

        function syncPicker() {
          var value = normalize(textInput.value);
          if (value === '') {
            return;
          }

          if (value[0] !== '#') {
            value = '#' + value;
          }

          if (/^#[0-9a-fA-F]{6}$/.test(value)) {
            picker.value = value;
          }
        }

        picker.addEventListener('input', function () {
          textInput.value = picker.value;
        });

        textInput.addEventListener('input', syncPicker);
        syncPicker();
      })();
    </script>
  </section>
{% endblock %}
