{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    <section class="nc-section" aria-label="Detalhes da agenda" data-aos="fade-up" data-aos-delay="0">
      {% set current_event = agenda_event|default(null) %}
      {% include 'components/section-header.twig' with {
        kicker: current_event.category_name|default(agenda.kicker|default('Agenda')),
        title: current_event.title|default(agenda.title|default('Atividade do CEDE')),
        lead: current_event.description|default(agenda.lead|default('Veja os detalhes deste encontro e organize sua participação na rotina fraterna da casa.'))
      } %}

      <ul class="nc-checklist">
        {% if current_event %}
          {% include 'components/check-item.twig' with {
            step: '01',
            title: 'Data e horário',
            description: current_event.starts_at_label|default('A definir') ~ (current_event.ends_at_label ? ' até ' ~ current_event.ends_at_label : ''),
            delay: 120
          } %}

          {% include 'components/check-item.twig' with {
            step: '02',
            title: 'Formato e local',
            description: current_event.mode_label|default('Presencial') ~ ' • ' ~ current_event.location_name|default('CEDE') ~ (current_event.location_address ? ' • ' ~ current_event.location_address : ''),
            delay: 180
          } %}

          {% if current_event.theme %}
            {% include 'components/check-item.twig' with {
              step: '03',
              title: 'Tema',
              description: current_event.theme,
              delay: 220
            } %}
          {% endif %}

          {% if current_event.audience %}
            {% include 'components/check-item.twig' with {
              step: '04',
              title: 'Público',
              description: current_event.audience,
              delay: 260
            } %}
          {% endif %}

          {% if current_event.notes %}
            {% include 'components/check-item.twig' with {
              step: '05',
              title: 'Observações',
              description: current_event.notes,
              delay: 300
            } %}
          {% endif %}
        {% else %}
          {% for topic in agenda.topics|default([]) %}
            {% include 'components/check-item.twig' with {
              step: topic.step,
              title: topic.title,
              description: topic.description,
              delay: topic.delay|default(120)
            } %}
          {% endfor %}
        {% endif %}
      </ul>

      <div class="nc-actions" data-aos="fade-up" data-aos-delay="160">
        <a class="nc-btn nc-btn-secondary" href="/agenda">Voltar para Agenda</a>
        {% if current_event and current_event.meeting_url %}
          <a class="nc-btn nc-btn-primary" href="{{ current_event.meeting_url }}" target="_blank" rel="noopener noreferrer">Entrar na atividade</a>
        {% else %}
          <a class="nc-btn nc-btn-primary" href="/contato">Entrar em contato</a>
        {% endif %}
      </div>
    </section>
  </main>
{% endblock %}
