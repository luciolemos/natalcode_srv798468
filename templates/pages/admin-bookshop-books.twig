{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = 'Acervo da Livraria' %}
{% set dashboard_page_lead = 'Cadastre os livros vendidos no balcão, revise estoque e mantenha o SKU alinhado com a planilha.' %}

{% block admin_content %}
  <section class="nc-section" aria-label="Administração do acervo da livraria" data-aos="fade-up" data-aos-delay="0">
    {% set toast_message = '' %}
    {% set toast_tone = 'success' %}
    {% if admin_status == 'created' %}
      {% set toast_message = 'Item criado com sucesso.' %}
    {% elseif admin_status == 'updated' %}
      {% set toast_message = 'Item atualizado com sucesso.' %}
    {% elseif admin_status == 'deleted' %}
      {% set toast_message = 'Item excluído com sucesso.' %}
    {% elseif admin_status == 'not-found' %}
      {% set toast_message = 'Item não encontrado.' %}
      {% set toast_tone = 'error' %}
    {% elseif admin_status == 'delete-blocked' %}
      {% set toast_message = 'Este item já participa de vendas registradas e não pode ser excluído.' %}
      {% set toast_tone = 'error' %}
    {% elseif admin_status == 'delete-error' %}
      {% set toast_message = 'Não foi possível excluir o item agora.' %}
      {% set toast_tone = 'error' %}
    {% endif %}

    {% include 'components/admin-toast.twig' with {
      message: toast_message,
      tone: toast_tone
    } %}

    <div class="nc-actions nc-bookshop-toolbar" data-aos="fade-up" data-aos-delay="60">
      <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel">Voltar ao painel</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria">Visão geral</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/colecoes">Coleções</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/categorias">Categorias doutrinárias</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/generos">Gêneros literários</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/importar">Importar CSV</a>
      <a class="nc-btn nc-btn-secondary" href="/painel/livraria/vendas">Vendas</a>
      <a class="nc-btn nc-btn-primary nc-actions-edge-button" href="/painel/livraria/acervo/novo">+ Novo livro</a>
    </div>

    {% set pagination = bookshop_books_pagination|default({}) %}
    {% set sort_links = bookshop_books_sort_links|default({}) %}
    {% set search_term = bookshop_books_search|default('') %}
    {% set filters = bookshop_books_filters|default({}) %}

      <form class="nc-admin-table-search" method="get" action="/painel/livraria/acervo" data-aos="fade-up" data-aos-delay="95">
        <label for="nc-bookshop-books-search">Buscar no acervo</label>
        <div class="nc-admin-table-search-controls nc-bookshop-table-filters">
        <input id="nc-bookshop-books-search" name="q" type="search" value="{{ search_term }}" placeholder="SKU, título, autor, coleção, volume, categoria doutrinária, gênero literário, editora, ISBN, código de barras, localização...">
        <select name="status_filter" aria-label="Filtrar por status">
          <option value="all" {{ filters.status_filter|default('all') == 'all' ? 'selected' : '' }}>Todos os status</option>
          <option value="active" {{ filters.status_filter|default('all') == 'active' ? 'selected' : '' }}>Somente ativos</option>
          <option value="inactive" {{ filters.status_filter|default('all') == 'inactive' ? 'selected' : '' }}>Somente inativos</option>
        </select>
        <select name="stock_filter" aria-label="Filtrar por estoque">
          <option value="all" {{ filters.stock_filter|default('all') == 'all' ? 'selected' : '' }}>Todo o estoque</option>
          <option value="ok" {{ filters.stock_filter|default('all') == 'ok' ? 'selected' : '' }}>Em estoque</option>
          <option value="low" {{ filters.stock_filter|default('all') == 'low' ? 'selected' : '' }}>Estoque baixo</option>
          <option value="out" {{ filters.stock_filter|default('all') == 'out' ? 'selected' : '' }}>Sem estoque</option>
        </select>
        <input type="hidden" name="sort" value="{{ pagination.sort|default('title') }}">
        <input type="hidden" name="dir" value="{{ pagination.dir|default('asc') }}">
        <input type="hidden" name="per_page" value="{{ pagination.page_size|default(10) }}">
        <button class="nc-btn nc-btn-secondary" type="submit">Aplicar</button>
      </div>
    </form>

    {% if bookshop_books|length == 0 %}
      <article class="nc-card nc-bookshop-empty-card" data-aos="fade-up" data-aos-delay="120">
        <p>{{ search_term or filters.status_filter != 'all' or filters.stock_filter != 'all' ? 'Nenhum item encontrado para os filtros informados.' : 'Nenhum item cadastrado ainda no acervo da livraria.' }}</p>
      </article>
    {% else %}
      <div class="nc-admin-table-toolbar" data-aos="fade-up" data-aos-delay="120">
        <p class="nc-admin-table-counter">
          Mostrando {{ pagination.start_item }}-{{ pagination.end_item }} de {{ pagination.total_items }} títulos · {{ pagination.total_units|default(0) }} exemplares em estoque
        </p>

        <form class="nc-admin-table-page-size" method="get" action="/painel/livraria/acervo">
          <label for="nc-bookshop-books-per-page">Registros por página</label>
          <select id="nc-bookshop-books-per-page" name="per_page" onchange="this.form.submit()">
            {% for option in pagination.page_size_options %}
              <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.value }}</option>
            {% endfor %}
          </select>
          <input type="hidden" name="sort" value="{{ pagination.sort|default('title') }}">
          <input type="hidden" name="dir" value="{{ pagination.dir|default('asc') }}">
          <input type="hidden" name="q" value="{{ search_term }}">
          <input type="hidden" name="status_filter" value="{{ filters.status_filter|default('all') }}">
          <input type="hidden" name="stock_filter" value="{{ filters.stock_filter|default('all') }}">
        </form>
      </div>

      <div class="nc-admin-table-wrap" data-aos="fade-up" data-aos-delay="140">
        <table class="nc-admin-table nc-admin-table-bookshop">
          <thead>
            <tr>
              <th>Capa</th>
              <th><a class="nc-admin-sort-link{% if sort_links.title.active %} is-active{% endif %}" href="{{ sort_links.title.url }}">Título <span aria-hidden="true">{{ sort_links.title.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.author_name.active %} is-active{% endif %}" href="{{ sort_links.author_name.url }}">Autor <span aria-hidden="true">{{ sort_links.author_name.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.genre_name.active %} is-active{% endif %}" href="{{ sort_links.genre_name.url }}">Gênero literário <span aria-hidden="true">{{ sort_links.genre_name.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.category_name.active %} is-active{% endif %}" href="{{ sort_links.category_name.url }}">Categoria doutrinária <span aria-hidden="true">{{ sort_links.category_name.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.isbn.active %} is-active{% endif %}" href="{{ sort_links.isbn.url }}">ISBN <span aria-hidden="true">{{ sort_links.isbn.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.barcode.active %} is-active{% endif %}" href="{{ sort_links.barcode.url }}">Código de barras <span aria-hidden="true">{{ sort_links.barcode.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.stock_quantity.active %} is-active{% endif %}" href="{{ sort_links.stock_quantity.url }}">Estoque <span aria-hidden="true">{{ sort_links.stock_quantity.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.sale_price.active %} is-active{% endif %}" href="{{ sort_links.sale_price.url }}">Venda <span aria-hidden="true">{{ sort_links.sale_price.indicator }}</span></a></th>
              <th><a class="nc-admin-sort-link{% if sort_links.status.active %} is-active{% endif %}" href="{{ sort_links.status.url }}">Status <span aria-hidden="true">{{ sort_links.status.indicator }}</span></a></th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            {% for book in bookshop_books %}
              <tr>
                <td data-label="Capa">
                  <div class="nc-library-admin-cover-thumb-wrap" aria-hidden="true">
                    {% if book.cover_image_url|default('') %}
                      <img
                        class="nc-library-admin-cover-thumb"
                        src="{{ book.cover_image_url }}"
                        alt=""
                        loading="lazy"
                      >
                    {% else %}
                      {% include 'components/library-bookplate-fallback.twig' with {
                        bookplate_title: book.title|default('livro'),
                        bookplate_author: book.author_name|default(''),
                        bookplate_collection_label: 'Livraria CEDE',
                        bookplate_section_title: 'Livraria',
                        bookplate_modifier_class: 'is-admin-list-thumb'
                      } only %}
                    {% endif %}
                  </div>
                </td>
                <td class="nc-agenda-activity-cell" data-label="Título">
                  <strong>{{ book.title }}</strong>
                  {% if book.subtitle|default('') %}
                    <small>{{ book.subtitle }}</small>
                  {% endif %}
                  {% if book.collection_name|default('') %}
                    <small>
                      Coleção: {{ book.collection_name }}{% if book.volume_number|default(null) %} · Vol. {{ book.volume_number }}{% endif %}{% if book.volume_label|default('') %} · {{ book.volume_label }}{% endif %}
                    </small>
                  {% endif %}
                  {% if book.location_label|default('') %}
                    <small>Localização: {{ book.location_label }}</small>
                  {% endif %}
                  {% if book.stock_lot_summary|default('') %}
                    <small>Lotes: {{ book.stock_lot_summary }}</small>
                  {% endif %}
                </td>
                <td data-label="Autor">{{ book.author_name|default('-') }}</td>
                <td data-label="Gênero literário">{{ book.genre_name|default('-') ?: '-' }}</td>
                <td data-label="Categoria doutrinária">{{ book.category_name|default('-') ?: '-' }}</td>
                <td class="nc-admin-cell-code" data-label="ISBN">{{ book.isbn|default('-') ?: '-' }}</td>
                <td class="nc-admin-cell-code" data-label="Código de barras">{{ book.barcode|default('-') ?: '-' }}</td>
                <td data-label="Estoque">
                  <span class="nc-bookshop-stock-pill is-{{ book.stock_state|default('ok') }}">{{ book.stock_quantity|default(0) }}</span>
                  <small>{{ book.stock_state_label|default('') }}</small>
                </td>
                <td data-label="Venda">{{ book.sale_price_label|default('R$ 0,00') }}</td>
                <td data-label="Status">
                  <span class="nc-admin-featured-flag{{ book.status == 'active' ? ' is-on' : ' is-off' }}">{{ book.status_label|default('-') }}</span>
                </td>
                <td class="nc-admin-table-actions" data-label="Ações">
                  <a class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-edit" href="/painel/livraria/acervo/{{ book.id }}/editar" aria-label="Editar item {{ book.title }}" title="Editar">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M4 20H8L18.5 9.5C19.3 8.7 19.3 7.3 18.5 6.5L17.5 5.5C16.7 4.7 15.3 4.7 14.5 5.5L4 16V20Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="nc-sr-only">Editar</span>
                  </a>
                  <a class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-open" href="/painel/livraria/acervo/{{ book.id }}" aria-label="Visualizar {{ book.title }}" title="Visualizar">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <ellipse cx="12" cy="12" rx="10" ry="6.5" stroke="currentColor" stroke-width="1.8"/>
                      <circle cx="12" cy="12" r="2.5" stroke="currentColor" stroke-width="1.8"/>
                    </svg>
                    <span class="nc-sr-only">Visualizar</span>
                  </a>
                  <form method="post" action="/painel/livraria/acervo/{{ book.id }}/excluir" onsubmit="return confirm('Tem certeza que deseja excluir este item do acervo?');">
                    <button class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-delete" type="submit" aria-label="Excluir item {{ book.title }}" title="Excluir">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M4 7H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        <path d="M9 11V17M15 11V17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        <path d="M7 7L8 19C8.08 19.9 8.84 20.6 9.75 20.6H14.25C15.16 20.6 15.92 19.9 16 19L17 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M10 4H14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                      </svg>
                      <span class="nc-sr-only">Excluir</span>
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if pagination.total_pages > 1 %}
        <nav class="nc-admin-pagination" aria-label="Paginação do acervo" data-aos="fade-up" data-aos-delay="170">
          {% if pagination.previous_url %}
            <a class="nc-link" href="{{ pagination.previous_url }}">← Anterior</a>
          {% else %}
            <span class="is-disabled">← Anterior</span>
          {% endif %}

          <div class="nc-admin-pagination-pages">
            {% for link in pagination.links %}
                {% if link.is_gap|default(false) %}
                  <span class="is-disabled" aria-hidden="true">{{ link.number }}</span>
                {% else %}
                  <a class="nc-link{% if link.active %} is-active{% endif %}" href="{{ link.url }}">{{ link.number }}</a>
                {% endif %}
            {% endfor %}
          </div>

          {% if pagination.next_url %}
            <a class="nc-link" href="{{ pagination.next_url }}">Próxima →</a>
          {% else %}
            <span class="is-disabled">Próxima →</span>
          {% endif %}
        </nav>
      {% endif %}
    {% endif %}
  </section>
{% endblock %}
