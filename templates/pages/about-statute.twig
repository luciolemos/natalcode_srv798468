{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    <section class="nc-section nc-about-statute-copy" aria-label="Estatuto do CEDE" data-aos="fade-up" data-aos-delay="0">
      {% include 'components/section-header.twig' with {
        kicker: statute.kicker|default('Quem Somos'),
        title: statute.title|default('ESTATUTO'),
        lead: 'Consulte abaixo o texto integral do Estatuto do Centro de Estudos da Doutrina Espírita (CEDE).'
      } %}

      {% if statute.updated_at_label|default('') %}
        <p class="nc-statute-meta" data-aos="fade-up" data-aos-delay="80">
          Última atualização: {{ statute.updated_at_label }}
        </p>
      {% endif %}

      <article class="nc-card nc-statute-card" data-aos="fade-up" data-aos-delay="120">
        <div class="nc-statute-text">{{ statute.body|default('Conteúdo do estatuto indisponível no momento.') }}</div>
      </article>

      <div class="nc-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="160">
        <a class="nc-btn nc-btn-secondary" href="/quem-somos">Voltar para Quem Somos</a>
        <a class="nc-btn nc-btn-primary" href="/contato">Falar com o CEDE</a>
      </div>
    </section>
  </main>
{% endblock %}
