{% extends 'layouts/base.twig' %}

{% block head %}
  {{ parent() }}
  <script src="/assets/js/cedern-portfolio-preview.js?v={{ app_asset_version|default('1') }}" defer></script>
{% endblock %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    {% set portfolio = site.portfolio|default({}) %}
    {% set portfolio_items = portfolio.items|default([]) %}

    <section class="nc-section nc-about-detail-copy nc-portfolio-showcase" aria-label="Portfolio de projetos digitais">
      {% include 'components/section-header.twig' with {
        kicker: portfolio.kicker|default('Portfolio'),
        title: portfolio.title|default('Catalogo de projetos'),
        lead: (
          (portfolio.lead|default('Veja exemplos de landing pages e sites desenvolvidos pela NatalCode.')) ~
          (portfolio.note is not empty ? ' ' ~ portfolio.note : '')
        )
      } %}

      <div class="nc-trust-grid" data-aos="fade-up" data-aos-delay="80">
        {% for item in portfolio_items %}
          <article class="nc-trust-card" style="--trust-enter-delay: {{ 80 + (loop.index0 * 90) }}ms;">
            {% if item.image is not empty %}
              <div class="nc-trust-media-wrapper">
                <img
                  class="nc-trust-media"
                  src="{{ item.image }}"
                  alt="{{ item.alt|default(item.title|default('Projeto')) }}"
                  loading="lazy"
                  decoding="async"
                >
                <a
                  class="nc-portfolio-media-preview"
                  href="#"
                  data-portfolio-preview-trigger
                  data-preview-image="{{ item.image }}"
                  data-preview-title="{{ item.title|default('Projeto') }}"
                  aria-label="Abrir preview de {{ item.title|default('Projeto') }}"
                >
                  <span class="nc-portfolio-media-preview-icon">+</span>
                  <span class="nc-portfolio-media-preview-label">Preview</span>
                </a>
              </div>
            {% endif %}

            <div class="nc-trust-body">
              <h3>{{ item.title|default('Projeto') }}</h3>
              <p>
                <strong>{{ item.segment|default('Site Web') }}</strong>
                {% if item.category is not empty %}
                  • {{ item.category }}
                {% endif %}
              </p>
              <p>{{ item.summary|default('Projeto sem descricao cadastrada.') }}</p>

              {% if item.url is not empty %}
                {% set is_external = item.url starts with 'http' %}
                <div class="nc-actions">
                  <a
                    class="nc-btn nc-btn-secondary"
                    href="{{ item.url }}"
                    {% if is_external %}target="_blank" rel="noopener noreferrer"{% endif %}
                  >{{ item.urlLabel|default('Ver detalhes') }}</a>
                  <a
                    class="nc-btn nc-btn-primary"
                    href="/contato?segmento={{ item.segmentKey|default(item.segment|default('site'))|url_encode }}"
                  >Quero um igual</a>
                </div>
              {% endif %}
            </div>
          </article>
        {% else %}
          <article class="nc-trust-card">
            <div class="nc-trust-body">
            <h3>Portfolio em atualizacao</h3>
            <p>Os estudos de caso serao publicados em breve.</p>
            </div>
          </article>
        {% endfor %}
      </div>

      <dialog class="nc-portfolio-preview-dialog" data-portfolio-preview-dialog aria-label="Preview da imagem do projeto">
        <div class="nc-portfolio-preview-shell">
          <button class="nc-portfolio-preview-close" type="button" data-portfolio-preview-close aria-label="Fechar preview">Fechar</button>
          <div class="nc-portfolio-preview-stage" data-portfolio-preview-stage></div>
          <p class="nc-portfolio-preview-caption" data-portfolio-preview-caption hidden></p>
        </div>
      </dialog>
    </section>
  </main>
{% endblock %}
