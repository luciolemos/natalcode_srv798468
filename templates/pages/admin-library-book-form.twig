{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = library_book_form_is_edit ? 'Editar livro' : 'Novo livro' %}
{% set dashboard_page_lead = 'Preencha os dados editoriais, envie o PDF e opcionalmente inclua uma capa para enriquecer a central de conteúdo pública.' %}

{% block admin_content %}
    <section class="nc-section" aria-label="Formulário de conteúdo da central de conteúdo" data-aos="fade-up" data-aos-delay="0">
      {% if library_book_form_errors|length > 0 %}
        <article class="nc-admin-form-errors" role="alert">
          <strong>Corrija os campos abaixo:</strong>
          <ul>
            {% for error in library_book_form_errors %}
              <li>{{ error }}</li>
            {% endfor %}
          </ul>
        </article>
      {% endif %}

      <div class="nc-actions nc-admin-toolbar" data-aos="fade-up" data-aos-delay="60">
        <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel">Voltar ao painel</a>
        <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel/biblioteca/livros">Voltar</a>
      </div>

      {% if library_book_categories|length == 0 %}
        <article class="nc-admin-form-errors" role="alert">
          <strong>Nenhuma categoria disponível.</strong>
          <ul>
            <li>Cadastre ao menos uma categoria antes de salvar este conteúdo.</li>
          </ul>
        </article>
      {% endif %}

      <article class="nc-card nc-admin-form-card">
        <form class="nc-admin-form" method="post" enctype="multipart/form-data" action="{{ library_book_form_is_edit ? '/painel/biblioteca/livros/' ~ library_book_id ~ '/editar' : '/painel/biblioteca/livros/novo' }}">
          <div class="nc-admin-form-grid nc-admin-form-grid-identity">
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="category_id">Categoria</label>
              <select class="nc-admin-form-input" id="category_id" name="category_id" required>
                <option value="" {% if library_book_form.category_id|default('') == '' %}selected{% endif %} disabled>Selecione uma categoria</option>
                {% for category in library_book_categories %}
                  <option value="{{ category.value }}"{% if category.selected %} selected{% endif %}>{{ category.label }}</option>
                {% endfor %}
              </select>
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="title">Título</label>
              <input class="nc-admin-form-input" id="title" name="title" type="text" required placeholder="Ex: O Livro dos Espíritos" value="{{ library_book_form.title|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="slug">Slug</label>
              <input class="nc-admin-form-input" id="slug" name="slug" type="text" placeholder="Ex: o-livro-dos-espiritos" value="{{ library_book_form.slug|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="status">Status</label>
              <select class="nc-admin-form-input" id="status" name="status" required>
                <option value="draft" {{ library_book_form.status|default('draft') == 'draft' ? 'selected' : '' }}>Rascunho</option>
                <option value="published" {{ library_book_form.status|default('draft') == 'published' ? 'selected' : '' }}>Publicado</option>
              </select>
            </div>
          </div>

          <div class="nc-admin-form-grid">
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="subtitle">Subtítulo</label>
              <input class="nc-admin-form-input" id="subtitle" name="subtitle" type="text" placeholder="Opcional" value="{{ library_book_form.subtitle|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="author_name">Autor principal</label>
              <input class="nc-admin-form-input" id="author_name" name="author_name" type="text" required placeholder="Ex: Allan Kardec" value="{{ library_book_form.author_name|default('') }}">
            </div>
          </div>

          <div class="nc-admin-form-grid">
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="organizer_name">Organização</label>
              <input class="nc-admin-form-input" id="organizer_name" name="organizer_name" type="text" placeholder="Opcional" value="{{ library_book_form.organizer_name|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="translator_name">Tradução</label>
              <input class="nc-admin-form-input" id="translator_name" name="translator_name" type="text" placeholder="Opcional" value="{{ library_book_form.translator_name|default('') }}">
            </div>
          </div>

          <div class="nc-admin-form-grid nc-admin-form-grid-triplet">
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="publisher_name">Editora</label>
              <input class="nc-admin-form-input" id="publisher_name" name="publisher_name" type="text" placeholder="Ex: FEB" value="{{ library_book_form.publisher_name|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="publication_city">Cidade</label>
              <input class="nc-admin-form-input" id="publication_city" name="publication_city" type="text" placeholder="Ex: Brasília" value="{{ library_book_form.publication_city|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="publication_year">Ano</label>
              <input class="nc-admin-form-input" id="publication_year" name="publication_year" type="number" min="1400" max="2100" placeholder="Ex: 2024" value="{{ library_book_form.publication_year|default('') }}">
            </div>
          </div>

          <div class="nc-admin-form-grid nc-admin-form-grid-triplet">
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="edition_label">Edição</label>
              <input class="nc-admin-form-input" id="edition_label" name="edition_label" type="text" placeholder="Ex: 2ª edição revisada" value="{{ library_book_form.edition_label|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="isbn">ISBN</label>
              <input class="nc-admin-form-input" id="isbn" name="isbn" type="text" placeholder="Ex: 978-85-..." value="{{ library_book_form.isbn|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="page_count">Páginas</label>
              <input class="nc-admin-form-input" id="page_count" name="page_count" type="number" min="1" placeholder="Ex: 320" value="{{ library_book_form.page_count|default('') }}">
            </div>
          </div>

          <div class="nc-admin-form-grid">
            <div class="nc-admin-form-field nc-library-admin-cover-field">
              <label class="nc-admin-form-label" for="cover_image_file">Capa do livro</label>
              <div class="nc-library-admin-cover-preview-wrap">
                {% set admin_cover_image_url = library_book_form.cover_image_url|default('')|trim %}
                {% set admin_cover_remove_requested = library_book_form.remove_cover_image|default(false) %}
                {% if admin_cover_image_url and not admin_cover_remove_requested %}
                  <img
                    class="nc-library-admin-cover-preview"
                    src="{{ admin_cover_image_url }}"
                    alt="Pré-visualização da capa de {{ library_book_form.title|default('livro') }}"
                  >
                {% else %}
                  {% include 'components/library-bookplate-fallback.twig' with {
                    bookplate_title: library_book_form.title|default('livro'),
                    bookplate_author: library_book_form.author_name|default(''),
                    bookplate_modifier_class: 'is-admin-preview'
                  } only %}
                {% endif %}
              </div>
              <input class="nc-admin-form-input" id="cover_image_file" name="cover_image_file" type="file" accept="image/jpeg,image/png,image/webp">
              {% if admin_cover_image_url %}
                <label class="nc-admin-form-checkbox nc-library-admin-cover-remove-option">
                  <input id="remove_cover_image" name="remove_cover_image" type="checkbox" value="1" {{ admin_cover_remove_requested ? 'checked' : '' }}>
                  <span>Usar a capa padrão do acervo neste conteúdo</span>
                </label>
              {% endif %}
              <p class="nc-admin-statute-meta">
                Envie uma imagem JPG, PNG ou WEBP com até 5MB. Se nenhuma capa for cadastrada, ou se a opção acima for marcada, a central de conteúdo exibirá a capa padrão do acervo.
              </p>
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="language">Idioma</label>
              <input class="nc-admin-form-input" id="language" name="language" type="text" placeholder="Ex: Português" value="{{ library_book_form.language|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="pdf_file">PDF do livro</label>
              <input class="nc-admin-form-input" id="pdf_file" name="pdf_file" type="file" accept="application/pdf"{% if not library_book_form.pdf_path|default('') %} required{% endif %}>
              {% if library_book_form.pdf_url|default('') %}
                <p class="nc-admin-statute-meta">Arquivo atual: <a class="nc-link" href="{{ library_book_form.pdf_url }}" target="_blank" rel="noopener">abrir PDF</a>{% if library_book_form.pdf_size_label|default('') %} • {{ library_book_form.pdf_size_label }}{% endif %}</p>
              {% endif %}
            </div>
          </div>

          <div class="nc-admin-form-field nc-admin-form-field-full">
            <label class="nc-admin-form-label" for="description">Descrição / Sinopse</label>
            <textarea class="nc-admin-form-input" id="description" name="description" rows="5" placeholder="Resumo editorial, objetivo da obra e observações para o leitor.">{{ library_book_form.description|default('') }}</textarea>
          </div>

          <div class="nc-actions nc-admin-form-actions" data-aos="fade-up" data-aos-delay="120">
            <button class="nc-btn nc-btn-primary nc-admin-action-create" type="submit">{{ library_book_form_is_edit ? 'Salvar alterações' : 'Criar conteúdo' }}</button>
            <a class="nc-btn nc-btn-secondary nc-admin-action-edit nc-btn-back" href="/painel/biblioteca/livros">Voltar</a>
          </div>
        </form>
      </article>
    </section>
{% endblock %}
