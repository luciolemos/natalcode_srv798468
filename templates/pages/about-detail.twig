{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    <section class="nc-section nc-about-detail-copy" aria-label="Detalhes institucionais" data-aos="fade-up" data-aos-delay="0">
      {% include 'components/section-header.twig' with {
        kicker: about.kicker|default('Quem Somos'),
        title: about.title|default('NatalCode'),
        lead: about.lead|default('Conheça mais sobre nossa atuação institucional.')
      } %}

      <ul class="nc-checklist">
        {% for topic in about.topics|default([]) %}
          {% include 'components/check-item.twig' with {
            step: topic.step,
            title: topic.title,
            description: topic.description,
            delay: topic.delay|default(120)
          } %}
        {% endfor %}
      </ul>

      <div class="nc-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="160">
        <a class="nc-btn nc-btn-secondary" href="/quem-somos">Voltar para Quem Somos</a>
        <a class="nc-btn nc-btn-primary" href="/contato">Falar com o NatalCode</a>
      </div>
    </section>
  </main>
{% endblock %}
