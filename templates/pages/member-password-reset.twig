{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-home-flow">
    <section class="nc-section" aria-label="Redefinição de senha" data-aos="fade-up" data-aos-delay="0">
      <div class="nc-container">
        {% include 'components/section-header.twig' with {
          kicker: 'Acesso',
          title: 'Definir nova senha',
          lead: 'Crie uma nova senha para voltar a acessar sua área do membro.'
        } %}

        <article class="nc-card nc-admin-login-card">
          {% if member_password_reset_errors %}
            <div class="nc-admin-login-error" role="alert">
              <ul>
                {% for error in member_password_reset_errors %}
                  <li>{{ error }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          {% if member_password_reset_token_valid %}
            <form class="nc-admin-login-form" method="post" action="/redefinir-senha">
              <input type="hidden" name="token" value="{{ member_password_reset_token }}">

              {% if member_password_reset_email|default('') %}
                <div class="nc-admin-login-field">
                  <label class="nc-admin-login-label" for="reset_email">Conta</label>
                  <input class="nc-admin-login-input" id="reset_email" type="email" value="{{ member_password_reset_email }}" autocomplete="email" readonly>
                </div>
              {% endif %}

              <div class="nc-admin-login-field">
                <label class="nc-admin-login-label" for="password">Nova senha</label>
                <input class="nc-admin-login-input" id="password" name="password" type="password" autocomplete="new-password" placeholder="Mínimo de 8 caracteres" required>
              </div>

              <div class="nc-admin-login-field">
                <label class="nc-admin-login-label" for="password_confirmation">Confirmar nova senha</label>
                <input class="nc-admin-login-input" id="password_confirmation" name="password_confirmation" type="password" autocomplete="new-password" placeholder="Repita a nova senha" required>
              </div>

              <div class="nc-actions nc-admin-login-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="80">
                <button class="nc-btn nc-btn-primary nc-admin-login-submit" type="submit">Salvar nova senha</button>
                <a class="nc-btn nc-btn-secondary nc-admin-login-back" href="/entrar">Voltar ao login</a>
              </div>

              <p class="nc-admin-login-footnote">
                Sua senha precisa ter pelo menos 8 caracteres, com 1 letra maiúscula e 1 número.
              </p>
            </form>
          {% else %}
            <div class="nc-admin-login-form">
              <p class="nc-admin-login-footnote">Solicite um novo link para continuar a redefinição da sua senha.</p>
              <div class="nc-actions nc-admin-login-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="80">
                <a class="nc-btn nc-btn-primary nc-admin-login-submit" href="/esqueci-senha">Solicitar novo link</a>
                <a class="nc-btn nc-btn-secondary nc-admin-login-back" href="/entrar">Voltar ao login</a>
              </div>
            </div>
          {% endif %}
        </article>
      </div>
    </section>
  </main>
{% endblock %}
