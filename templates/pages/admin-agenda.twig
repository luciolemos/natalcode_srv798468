{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = 'Gerenciar Agenda' %}
{% set dashboard_page_lead = 'Cadastre, edite e exclua eventos que aparecem na agenda pública.' %}

{% block admin_content %}
    <section class="nc-section" aria-label="Administração da agenda" data-aos="fade-up" data-aos-delay="0">
      {% set toast_message = '' %}
      {% set toast_tone = 'success' %}
      {% if admin_status == 'created' %}
        {% set toast_message = 'Evento criado com sucesso.' %}
      {% elseif admin_status == 'updated' %}
        {% set toast_message = 'Evento atualizado com sucesso.' %}
      {% elseif admin_status == 'deleted' %}
        {% set toast_message = 'Evento excluído com sucesso.' %}
      {% elseif admin_status == 'not-found' %}
        {% set toast_message = 'Evento não encontrado.' %}
        {% set toast_tone = 'error' %}
      {% elseif admin_status == 'delete-error' %}
        {% set toast_message = 'Não foi possível excluir o evento.' %}
        {% set toast_tone = 'error' %}
      {% endif %}

      {% include 'components/admin-toast.twig' with {
        message: toast_message,
        tone: toast_tone
      } %}

      <div class="nc-actions" data-aos="fade-up" data-aos-delay="80">
        <a class="nc-btn nc-btn-primary nc-btn-icon nc-admin-action-create" href="/painel/eventos/novo" aria-label="Novo evento" title="Novo evento">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="3" y="4" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.8"/>
            <path d="M12 9V15M9 12H15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <span class="nc-sr-only">Novo evento</span>
        </a>
        <a class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-open" href="/agenda" aria-label="Ver agenda pública" title="Ver agenda pública">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M14 5H19V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 14L19 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="5" y="9" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.8"/>
          </svg>
          <span class="nc-sr-only">Ver agenda pública</span>
        </a>
      </div>

      {% set pagination = agenda_pagination|default({}) %}
      {% set sort_links = agenda_sort_links|default({}) %}
      {% set search_term = agenda_search|default('') %}

      {% if agenda_events|length == 0 %}
        <form class="nc-admin-table-search" method="get" action="/painel/eventos" data-aos="fade-up" data-aos-delay="95">
          <label for="nc-agenda-search">Buscar eventos</label>
          <div class="nc-admin-table-search-controls">
            <input id="nc-agenda-search" name="q" type="search" value="{{ search_term }}" placeholder="Título, categoria, slug, status...">
            <input type="hidden" name="sort" value="{{ pagination.sort|default('starts_at') }}">
            <input type="hidden" name="dir" value="{{ pagination.dir|default('asc') }}">
            <input type="hidden" name="per_page" value="{{ pagination.page_size|default(5) }}">
            <button class="nc-btn nc-btn-secondary" type="submit">Buscar</button>
          </div>
        </form>
        <p>{{ search_term ? 'Nenhum evento encontrado para a busca informada.' : 'Nenhum evento cadastrado.' }}</p>
      {% else %}
        <form class="nc-admin-table-search" method="get" action="/painel/eventos" data-aos="fade-up" data-aos-delay="95">
          <label for="nc-agenda-search">Buscar eventos</label>
          <div class="nc-admin-table-search-controls">
            <input id="nc-agenda-search" name="q" type="search" value="{{ search_term }}" placeholder="Título, categoria, slug, status...">
            <input type="hidden" name="sort" value="{{ pagination.sort|default('starts_at') }}">
            <input type="hidden" name="dir" value="{{ pagination.dir|default('asc') }}">
            <input type="hidden" name="per_page" value="{{ pagination.page_size|default(5) }}">
            <button class="nc-btn nc-btn-secondary" type="submit">Buscar</button>
          </div>
        </form>

        <div class="nc-admin-table-toolbar" data-aos="fade-up" data-aos-delay="110">
          <p class="nc-admin-table-counter">
            Mostrando {{ pagination.start_item }}-{{ pagination.end_item }} de {{ pagination.total_items }} registros
          </p>

          <form class="nc-admin-table-page-size" method="get" action="/painel/eventos">
            <label for="nc-per-page">Registros por página</label>
            <select id="nc-per-page" name="per_page" onchange="this.form.submit()">
              {% for option in pagination.page_size_options %}
                <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.value }}</option>
              {% endfor %}
            </select>
            <input type="hidden" name="sort" value="{{ pagination.sort|default('starts_at') }}">
            <input type="hidden" name="dir" value="{{ pagination.dir|default('asc') }}">
            <input type="hidden" name="q" value="{{ search_term }}">
            <noscript>
              <button class="nc-btn nc-btn-secondary" type="submit">Aplicar</button>
            </noscript>
          </form>
        </div>

        <div class="nc-admin-table-wrap" data-aos="fade-up" data-aos-delay="140">
          <table class="nc-admin-table">
            <thead>
              <tr>
                <th>
                  <a class="nc-admin-sort-link{% if sort_links.id.active %} is-active{% endif %}" href="{{ sort_links.id.url }}">ID <span aria-hidden="true">{{ sort_links.id.indicator }}</span></a>
                </th>
                <th>
                  <a class="nc-admin-sort-link{% if sort_links.title.active %} is-active{% endif %}" href="{{ sort_links.title.url }}">Título <span aria-hidden="true">{{ sort_links.title.indicator }}</span></a>
                </th>
                <th>
                  <a class="nc-admin-sort-link{% if sort_links.category_name.active %} is-active{% endif %}" href="{{ sort_links.category_name.url }}">Categoria <span aria-hidden="true">{{ sort_links.category_name.indicator }}</span></a>
                </th>
                <th>
                  <a class="nc-admin-sort-link{% if sort_links.starts_at.active %} is-active{% endif %}" href="{{ sort_links.starts_at.url }}">Início <span aria-hidden="true">{{ sort_links.starts_at.indicator }}</span></a>
                </th>
                <th>
                  <a class="nc-admin-sort-link{% if sort_links.status.active %} is-active{% endif %}" href="{{ sort_links.status.url }}">Status <span aria-hidden="true">{{ sort_links.status.indicator }}</span></a>
                </th>
                <th>
                  <a class="nc-admin-sort-link{% if sort_links.is_featured.active %} is-active{% endif %}" href="{{ sort_links.is_featured.url }}">Destacar <span aria-hidden="true">{{ sort_links.is_featured.indicator }}</span></a>
                </th>
                <th>
                  <a class="nc-admin-sort-link{% if sort_links.slug.active %} is-active{% endif %}" href="{{ sort_links.slug.url }}">Slug <span aria-hidden="true">{{ sort_links.slug.indicator }}</span></a>
                </th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              {% for event in agenda_events %}
                {% set event_status_key = event.status|default('') %}
                {% set event_status_label = {
                  'draft': 'Rascunho',
                  'published': 'Publicado',
                  'cancelled': 'Cancelado'
                }[event_status_key]|default(event_status_key ?: '-') %}
                <tr>
                  <td data-label="ID">{{ event.id }}</td>
                  <td data-label="Título">{{ event.title }}</td>
                  <td data-label="Categoria">{{ event.category_name|default('-') }}</td>
                  <td data-label="Início">{{ event.starts_at_label|default(event.starts_at) }}</td>
                  <td data-label="Status">{{ event_status_label }}</td>
                  <td data-label="Destacar">
                    <span class="nc-admin-featured-flag{{ event.is_featured ? ' is-on' : ' is-off' }}">{{ event.is_featured ? 'Sim' : 'Não' }}</span>
                  </td>
                  <td class="nc-admin-cell-slug" data-label="Slug" title="{{ event.slug }}"><span>{{ event.slug }}</span></td>
                  <td class="nc-admin-table-actions" data-label="Ações">
                    <a class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-edit" href="/painel/eventos/{{ event.id }}/editar" aria-label="Editar evento {{ event.title }}" title="Editar">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M4 20H8L18.5 9.5C19.3 8.7 19.3 7.3 18.5 6.5L17.5 5.5C16.7 4.7 15.3 4.7 14.5 5.5L4 16V20Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="nc-sr-only">Editar</span>
                    </a>
                    <form method="post" action="/painel/eventos/{{ event.id }}/excluir" onsubmit="return confirm('Tem certeza que deseja excluir este evento?');">
                      <button class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-delete" type="submit" aria-label="Excluir evento {{ event.title }}" title="Excluir">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M4 7H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                          <path d="M9 11V17M15 11V17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                          <path d="M7 7L8 19C8.08 19.9 8.84 20.6 9.75 20.6H14.25C15.16 20.6 15.92 19.9 16 19L17 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M10 4H14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        </svg>
                        <span class="nc-sr-only">Excluir</span>
                      </button>
                    </form>
                    <a class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-open" href="/agenda/{{ event.slug }}" aria-label="Abrir evento {{ event.title }} na área pública" title="Abrir">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M14 5H19V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M10 14L19 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <rect x="5" y="9" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.8"/>
                      </svg>
                      <span class="nc-sr-only">Abrir</span>
                    </a>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {% if pagination.total_pages > 1 %}
          <nav class="nc-admin-pagination" aria-label="Paginação da agenda" data-aos="fade-up" data-aos-delay="170">
            {% if pagination.previous_url %}
              <a class="nc-link" href="{{ pagination.previous_url }}">← Anterior</a>
            {% else %}
              <span class="is-disabled">← Anterior</span>
            {% endif %}

            <div class="nc-admin-pagination-pages">
              {% for link in pagination.links %}
                <a class="nc-link{% if link.active %} is-active{% endif %}" href="{{ link.url }}">{{ link.number }}</a>
              {% endfor %}
            </div>

            {% if pagination.next_url %}
              <a class="nc-link" href="{{ pagination.next_url }}">Próxima →</a>
            {% else %}
              <span class="is-disabled">Próxima →</span>
            {% endif %}
          </nav>
        {% endif %}
      {% endif %}
    </section>
{% endblock %}
