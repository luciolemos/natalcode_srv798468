{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-home-flow">
    <section class="nc-section" aria-label="Recuperação de senha" data-aos="fade-up" data-aos-delay="0">
      <div class="nc-container">
        {% include 'components/section-header.twig' with {
          kicker: 'Acesso',
          title: 'Recuperar senha',
          lead: 'Informe o e-mail cadastrado para receber um link seguro de redefinição.'
        } %}

        <article class="nc-card nc-admin-login-card">
          {% if member_password_forgot_success %}
            <div class="nc-admin-login-success nc-admin-login-success-panel" role="status">
              <p><strong>Solicitação registrada.</strong></p>
              <p>Se o e-mail informado estiver cadastrado e o serviço de envio estiver disponível, um link de redefinição será enviado e ficará válido por {{ member_password_forgot_ttl_minutes }} minutos.</p>
              <ul class="nc-admin-login-followup-list">
                <li>Verifique caixa de entrada, spam e promoções.</li>
                <li>Aguarde alguns minutos antes de solicitar novamente.</li>
                <li>Se o link não chegar, tente mais tarde ou fale com o NatalCode pelo <a class="nc-link" href="/contato">contato oficial</a>.</li>
              </ul>
            </div>

            <div class="nc-actions nc-admin-login-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="80">
              <a class="nc-btn nc-btn-primary nc-admin-login-submit" href="/esqueci-senha?novo=1">Solicitar novamente</a>
              <a class="nc-btn nc-btn-secondary nc-admin-login-back" href="/entrar">Voltar ao login</a>
            </div>

            <p class="nc-admin-login-footnote">
              Se precisar tentar com outro e-mail, use o botão "Solicitar novamente".
            </p>
          {% endif %}

          {% if not member_password_forgot_success %}
            {% if member_password_forgot_errors %}
              <div class="nc-admin-login-error" role="alert">
                <ul>
                  {% for error in member_password_forgot_errors %}
                    <li>{{ error }}</li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}

            <form class="nc-admin-login-form" method="post" action="/esqueci-senha"{% if app_recaptcha_enabled %} data-recaptcha-action="member_password_forgot" data-recaptcha-site-key="{{ app_recaptcha_site_key }}"{% endif %}>
          {% include 'components/csrf-field.twig' %}
              <div class="nc-admin-login-field">
                <label class="nc-admin-login-label" for="email">E-mail cadastrado</label>
                <input class="nc-admin-login-input" id="email" name="email" type="email" value="{{ member_password_forgot_form.email|default('') }}" autocomplete="email" placeholder="Ex: maria@email.com" required>
              </div>

              {% include 'components/recaptcha-fields.twig' %}

              <div class="nc-actions nc-admin-login-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="80">
                <button class="nc-btn nc-btn-primary nc-admin-login-submit" type="submit">Solicitar link de redefinição</button>
                <a class="nc-btn nc-btn-secondary nc-admin-login-back" href="/entrar">Voltar ao login</a>
              </div>

              <p class="nc-admin-login-footnote">
                O link, quando enviado, expira automaticamente e pode ser usado apenas uma vez.
              </p>
            </form>
          {% endif %}
        </article>
      </div>
    </section>
  </main>
{% endblock %}
