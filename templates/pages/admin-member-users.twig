{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = 'Usuários' %}
{% set dashboard_page_lead = 'Valide cadastros pendentes e atribua perfis de acesso aos frequentadores.' %}

{% block admin_content %}
  <section class="nc-section" aria-label="Administração de usuários" data-aos="fade-up" data-aos-delay="0">
    {% set toast_message = '' %}
    {% set toast_tone = 'success' %}
    {% if admin_status == 'approved' %}
      {% set toast_message = 'Usuário aprovado e perfil atualizado com sucesso.' %}
    {% elseif admin_status == 'invalid-role' %}
      {% set toast_message = 'Selecione um perfil válido para continuar.' %}
      {% set toast_tone = 'error' %}
    {% elseif admin_status == 'assign-error' %}
      {% set toast_message = 'Não foi possível salvar o perfil do usuário agora. Tente novamente.' %}
      {% set toast_tone = 'error' %}
    {% elseif admin_status == 'load-error' %}
      {% set toast_message = admin_error_message|default('Não foi possível carregar os usuários no momento.') %}
      {% set toast_tone = 'error' %}
    {% endif %}

    {% include 'components/admin-toast.twig' with {
      message: toast_message,
      tone: toast_tone
    } %}

    {% set pagination = member_users_pagination|default({}) %}
    {% set sort_links = member_users_sort_links|default({}) %}
    {% set search_term = member_users_search|default('') %}

    {% if member_users|length == 0 %}
      <form class="nc-admin-table-search" method="get" action="/painel/usuarios" data-aos="fade-up" data-aos-delay="95">
        <label for="nc-users-search">Buscar usuários</label>
        <div class="nc-admin-table-search-controls">
          <input id="nc-users-search" name="q" type="search" value="{{ search_term }}" placeholder="Nome, e-mail, status, perfil...">
          <input type="hidden" name="sort" value="{{ pagination.sort|default('id') }}">
          <input type="hidden" name="dir" value="{{ pagination.dir|default('desc') }}">
          <input type="hidden" name="per_page" value="{{ pagination.page_size|default(10) }}">
          <button class="nc-btn nc-btn-secondary" type="submit">Buscar</button>
        </div>
      </form>
      <p>{{ search_term ? 'Nenhum usuário encontrado para a busca informada.' : 'Nenhum usuário cadastrado até o momento.' }}</p>
    {% else %}
      <form class="nc-admin-table-search" method="get" action="/painel/usuarios" data-aos="fade-up" data-aos-delay="95">
        <label for="nc-users-search">Buscar usuários</label>
        <div class="nc-admin-table-search-controls">
          <input id="nc-users-search" name="q" type="search" value="{{ search_term }}" placeholder="Nome, e-mail, status, perfil...">
          <input type="hidden" name="sort" value="{{ pagination.sort|default('id') }}">
          <input type="hidden" name="dir" value="{{ pagination.dir|default('desc') }}">
          <input type="hidden" name="per_page" value="{{ pagination.page_size|default(10) }}">
          <button class="nc-btn nc-btn-secondary" type="submit">Buscar</button>
        </div>
      </form>

      <div class="nc-admin-table-toolbar" data-aos="fade-up" data-aos-delay="110">
        <p class="nc-admin-table-counter">
          Mostrando {{ pagination.start_item }}-{{ pagination.end_item }} de {{ pagination.total_items }} registros
        </p>

        <form class="nc-admin-table-page-size" method="get" action="/painel/usuarios">
          <label for="nc-users-per-page">Registros por página</label>
          <select id="nc-users-per-page" name="per_page" onchange="this.form.submit()">
            {% for option in pagination.page_size_options %}
              <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.value }}</option>
            {% endfor %}
          </select>
          <input type="hidden" name="sort" value="{{ pagination.sort|default('id') }}">
          <input type="hidden" name="dir" value="{{ pagination.dir|default('desc') }}">
          <input type="hidden" name="q" value="{{ search_term }}">
          <noscript>
            <button class="nc-btn nc-btn-secondary" type="submit">Aplicar</button>
          </noscript>
        </form>
      </div>

      <div class="nc-admin-table-wrap" data-aos="fade-up" data-aos-delay="80">
        <table class="nc-admin-table nc-admin-table-users">
          <thead>
            <tr>
              <th class="nc-admin-col-id">
                <a class="nc-admin-sort-link{% if sort_links.id.active %} is-active{% endif %}" href="{{ sort_links.id.url }}">ID <span aria-hidden="true">{{ sort_links.id.indicator }}</span></a>
              </th>
              <th>Foto</th>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.full_name.active %} is-active{% endif %}" href="{{ sort_links.full_name.url }}">Nome <span aria-hidden="true">{{ sort_links.full_name.indicator }}</span></a>
              </th>
              <th class="nc-admin-col-email">
                <a class="nc-admin-sort-link{% if sort_links.email.active %} is-active{% endif %}" href="{{ sort_links.email.url }}">E-mail <span aria-hidden="true">{{ sort_links.email.indicator }}</span></a>
              </th>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.status.active %} is-active{% endif %}" href="{{ sort_links.status.url }}">Status <span aria-hidden="true">{{ sort_links.status.indicator }}</span></a>
              </th>
              <th>
                <a class="nc-admin-sort-link{% if sort_links.role_name.active %} is-active{% endif %}" href="{{ sort_links.role_name.url }}">Perfil <span aria-hidden="true">{{ sort_links.role_name.indicator }}</span></a>
              </th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            {% for user in member_users %}
              <tr>
                {% set user_status_key = user.status|default('') %}
                {% set user_status_label = {
                  'pending': 'Pendente',
                  'active': 'Ativo',
                  'blocked': 'Bloqueado'
                }[user_status_key]|default(user_status_key ?: '-') %}
                <td class="nc-admin-col-id" data-label="ID">{{ user.id }}</td>
                <td class="nc-admin-user-photo-cell" data-label="Foto">
                  <span class="nc-admin-user-photo" aria-hidden="true">
                    {% if user.profile_photo_path|default('') %}
                      <img src="/{{ user.profile_photo_path }}" alt="">
                    {% else %}
                      <span>{{ (user.full_name|default(user.email|default('U'))|slice(0, 1)|upper) }}</span>
                    {% endif %}
                  </span>
                </td>
                <td data-label="Nome">
                  <span>{{ user.full_name|default('-') }}</span>
                  <small class="nc-admin-user-email-inline">{{ user.email|default('-') }}</small>
                </td>
                <td class="nc-admin-col-email" data-label="E-mail">{{ user.email|default('-') }}</td>
                <td data-label="Status">
                  <span class="nc-admin-featured-flag{{ user_status_key == 'active' ? ' is-on' : ' is-off' }}">{{ user_status_label }}</span>
                </td>
                <td data-label="Perfil">{{ user.role_name|default('-') }}</td>
                <td class="nc-admin-table-actions" data-label="Ações">
                  <form method="post" action="/painel/usuarios/{{ user.id }}/atribuir-papel" class="nc-admin-inline-form">
                    <select class="nc-admin-inline-select" name="role_id" aria-label="Selecionar perfil para {{ user.full_name|default('usuário') }}">
                      <option value="">Selecionar perfil</option>
                      {% for role in member_roles %}
                        <option value="{{ role.id }}"{% if user.role_key is defined and user.role_key == role.role_key %} selected{% endif %}>{{ role.name }}</option>
                      {% endfor %}
                    </select>
                    <button class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-edit" type="submit" aria-label="Salvar perfil de {{ user.full_name|default('usuário') }}" title="Salvar">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M5 4H16L20 8V20H5V4Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M8 4V10H16V4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <rect x="8" y="14" width="8" height="6" rx="1" stroke="currentColor" stroke-width="1.8"/>
                      </svg>
                      <span class="nc-sr-only">Salvar</span>
                    </button>
                    <a class="nc-btn nc-btn-secondary nc-btn-icon nc-admin-action-open" href="/painel/usuarios/{{ user.id }}/resumo" aria-label="Visualizar resumo de {{ user.full_name|default('usuário') }}" title="Visualizar">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M2 12C4.5 7.5 8 5.5 12 5.5C16 5.5 19.5 7.5 22 12C19.5 16.5 16 18.5 12 18.5C8 18.5 4.5 16.5 2 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/>
                      </svg>
                      <span class="nc-sr-only">Visualizar</span>
                    </a>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if pagination.total_pages > 1 %}
        <nav class="nc-admin-pagination" aria-label="Paginação de usuários" data-aos="fade-up" data-aos-delay="170">
          {% if pagination.previous_url %}
            <a class="nc-link" href="{{ pagination.previous_url }}">← Anterior</a>
          {% else %}
            <span class="is-disabled">← Anterior</span>
          {% endif %}

          <div class="nc-admin-pagination-pages">
            {% for link in pagination.links %}
              <a class="nc-link{% if link.active %} is-active{% endif %}" href="{{ link.url }}">{{ link.number }}</a>
            {% endfor %}
          </div>

          {% if pagination.next_url %}
            <a class="nc-link" href="{{ pagination.next_url }}">Próxima →</a>
          {% else %}
            <span class="is-disabled">Próxima →</span>
          {% endif %}
        </nav>
      {% endif %}
    {% endif %}
  </section>
{% endblock %}
