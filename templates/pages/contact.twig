{% extends 'layouts/base.twig' %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    {% set site_contact = site.contact|default({}) %}
    {% set contact_meta = site.footer|default({}) %}

    <section class="nc-section nc-contact-overview" aria-label="Contato" data-aos="fade-up" data-aos-delay="0">
      {% include 'components/section-header.twig' with {
        kicker: contact_meta.contactKicker|default('Contato'),
        title: contact_meta.contactTitle|default('Fale com a NatalCode'),
        lead: contact_meta.contactLead|default('Envie sua ideia e retornamos com próximo passo, escopo inicial e estimativa.')
      } %}

      <ul class="nc-checklist">
        {% include 'components/check-item.twig' with {
          step: '01',
          title: 'Envie o contexto',
          description: 'Conte objetivo, público e prazo desejado. Quanto mais claro, mais rápido o retorno.',
          delay: 120
        } %}
        {% include 'components/check-item.twig' with {
          step: '02',
          title: 'Receba diagnóstico inicial',
          description: 'Avaliamos requisitos, viabilidade e sugerimos a melhor linha de entrega.',
          delay: 160
        } %}
        {% include 'components/check-item.twig' with {
          step: '03',
          title: 'Proposta e próximos passos',
          description: 'Enviamos escopo, prazos e investimento para seguir com o projeto.',
          delay: 200
        } %}
      </ul>

      <article class="nc-card nc-admin-login-card">
        {% if contact_form_status == 'sent' %}
          <p class="nc-admin-login-success" role="status">Mensagem enviada com sucesso. Em breve retornaremos seu contato.</p>
        {% endif %}

        {% if contact_form_errors|default([]) %}
          <div class="nc-admin-login-error" role="alert">
            <ul>
              {% for error in contact_form_errors %}
                <li>{{ error }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        <form class="nc-admin-login-form" method="post" action="/contato"{% if app_recaptcha_enabled %} data-recaptcha-action="contact_submit" data-recaptcha-site-key="{{ app_recaptcha_site_key }}"{% endif %}>
          <div class="nc-admin-login-field">
            <label class="nc-admin-login-label" for="name">Nome *</label>
            <input class="nc-admin-login-input" id="name" name="name" type="text" value="{{ contact_form.name|default('') }}" placeholder="Ex: Maria Souza" autocomplete="name" required>
          </div>

          <div class="nc-admin-login-field">
            <label class="nc-admin-login-label" for="email">E-mail *</label>
            <input class="nc-admin-login-input" id="email" name="email" type="email" value="{{ contact_form.email|default('') }}" placeholder="Ex: maria@empresa.com" autocomplete="email" required>
          </div>

          <div class="nc-admin-login-field">
            <label class="nc-admin-login-label" for="subject">Objetivo principal *</label>
            <input class="nc-admin-login-input" id="subject" name="subject" type="text" value="{{ contact_form.subject|default('') }}" placeholder="Ex: Landing page para campanha ou novo site institucional" required>
          </div>

          <details class="nc-admin-login-field">
            <summary class="nc-admin-login-label">Adicionar detalhes (opcional)</summary>
            <textarea class="nc-admin-login-input" id="message" name="message" rows="5" placeholder="Conte contexto, público, prazo desejado e qualquer referência útil.">{{ contact_form.message|default('') }}</textarea>
          </details>

          <div class="nc-admin-login-field" style="display:none;" aria-hidden="true">
            <label class="nc-admin-login-label" for="company">Empresa</label>
            <input class="nc-admin-login-input" id="company" name="company" type="text" value="{{ contact_form.company|default('') }}" tabindex="-1" autocomplete="off">
          </div>

          {% include 'components/recaptcha-fields.twig' %}

          <div class="nc-actions nc-admin-login-actions nc-contact-form-actions is-stacked-mobile" data-aos="fade-up" data-aos-delay="120">
            <button class="nc-btn nc-btn-primary" type="submit">Enviar mensagem</button>
            {% if app_whatsapp_number|default('') %}
              <a
                class="nc-btn nc-btn-primary"
                href="https://wa.me/{{ app_whatsapp_number }}?text={{ app_whatsapp_message|default('')|url_encode }}"
                target="_blank"
                rel="noopener noreferrer"
              >Falar no WhatsApp</a>
            {% endif %}
            {% if site_contact.mapUrl|default('') %}
              <a class="nc-btn nc-btn-secondary" href="{{ site_contact.mapUrl }}" target="_blank" rel="noopener noreferrer">Ver no mapa</a>
            {% endif %}
          </div>
        </form>
      </article>

    </section>
  </main>
{% endblock %}
