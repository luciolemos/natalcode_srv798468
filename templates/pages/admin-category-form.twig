{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = agenda_category_form_is_edit ? 'Editar categoria' : 'Nova categoria' %}
{% set dashboard_page_lead = 'Preencha os dados para criar ou atualizar uma categoria da agenda.' %}

{% block admin_content %}
    <section class="nc-section" aria-label="Formulário de categoria" data-aos="fade-up" data-aos-delay="0">
      {% if agenda_category_form_errors|length > 0 %}
        <article class="nc-admin-form-errors" role="alert">
          <strong>Corrija os campos abaixo:</strong>
          <ul>
            {% for error in agenda_category_form_errors %}
              <li>{{ error }}</li>
            {% endfor %}
          </ul>
        </article>
      {% endif %}

      <div class="nc-actions nc-admin-toolbar" data-aos="fade-up" data-aos-delay="60">
        <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel">Voltar ao painel</a>
        <a class="nc-btn nc-btn-secondary nc-btn-back" href="/painel/categorias">Voltar</a>
      </div>

      <article class="nc-admin-form-card">
        <form class="nc-admin-form" method="post" action="{{ agenda_category_form_is_edit ? '/painel/categorias/' ~ agenda_category_id ~ '/editar' : '/painel/categorias/nova' }}">
          <div class="nc-admin-form-grid nc-admin-form-grid-category-head">
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="name">Nome da categoria</label>
              <input class="nc-admin-form-input" id="name" name="name" type="text" required placeholder="Ex: Palestra" value="{{ agenda_category_form.name|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="slug">Slug da categoria</label>
              <input class="nc-admin-form-input" id="slug" name="slug" type="text" required placeholder="Ex: palestra" value="{{ agenda_category_form.slug|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="is_active">Status da categoria</label>
              <select class="nc-admin-form-input" id="is_active" name="is_active" required>
                <option value="" {% if agenda_category_form.is_active|default('') == '' %}selected{% endif %} disabled>Selecione status</option>
                <option value="1" {{ agenda_category_form.is_active == '1' ? 'selected' : '' }}>Ativa</option>
                <option value="0" {{ agenda_category_form.is_active == '0' ? 'selected' : '' }}>Inativa</option>
              </select>
            </div>
          </div>

          <div class="nc-admin-form-grid">
            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="color">Cor (hex)</label>
              <input class="nc-admin-form-input" id="color" name="color" type="text" placeholder="Ex: #2563eb" value="{{ agenda_category_form.color|default('') }}">
            </div>

            <div class="nc-admin-form-field">
              <label class="nc-admin-form-label" for="icon">Ícone (opcional)</label>
              <input class="nc-admin-form-input" id="icon" name="icon" type="text" placeholder="Ex: calendar" value="{{ agenda_category_form.icon|default('') }}">
            </div>
          </div>

          <div class="nc-actions nc-admin-form-actions" data-aos="fade-up" data-aos-delay="120">
            <button class="nc-btn nc-btn-primary nc-admin-action-create" type="submit">{{ agenda_category_form_is_edit ? 'Salvar alterações' : 'Criar categoria' }}</button>
            <a class="nc-btn nc-btn-secondary nc-admin-action-edit nc-btn-back" href="/painel/categorias">Voltar</a>
          </div>
        </form>
      </article>
    </section>
{% endblock %}
