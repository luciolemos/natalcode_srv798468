{% extends 'layouts/admin-dashboard.twig' %}

{% set dashboard_page_kicker = 'Dashboard' %}
{% set dashboard_page_title = dashboard_page_title|default('Resumo do usuário') %}
{% set dashboard_page_lead = 'Visualização rápida dos principais dados cadastrais.' %}

{% block admin_content %}
  <section class="nc-section" aria-label="Resumo do usuário">
    <p>
      <a class="nc-btn nc-btn-secondary" href="/painel/usuarios">← Voltar para Gestão de Pessoal</a>
    </p>

    {% if summary_user is empty %}
      <p>{{ summary_error_message|default('Usuário não encontrado.') }}</p>
    {% else %}
      <article class="nc-card nc-member-panel" data-aos="fade-up" data-aos-delay="70">
        <div class="nc-member-header">
          <div class="nc-member-avatar-wrap" aria-hidden="true">
            {% if summary_user.profile_photo_path|default('') %}
              <img class="nc-member-avatar" src="/{{ summary_user.profile_photo_path }}" alt="">
            {% else %}
              <div class="nc-member-avatar-placeholder">{{ (summary_user.full_name|default(summary_user.email|default('U'))|slice(0, 1)|upper) }}</div>
            {% endif %}
          </div>
          <div class="nc-member-header-text">
            <h3>Dados do cadastro</h3>
            <p>Essas informações ficam associadas à conta de membro.</p>
          </div>
        </div>

        <dl class="nc-member-grid">
          <div>
            <dt>Perfil</dt>
            <dd>{{ summary_user.role_name|default('Membro') }}</dd>
          </div>
          <div>
            <dt>E-mail</dt>
            <dd>{{ summary_user.email|default('-') }}</dd>
          </div>
          <div>
            <dt>Celular</dt>
            <dd>{{ summary_user.phone_mobile|default('-') }}</dd>
          </div>
          <div>
            <dt>Telefone</dt>
            <dd>{{ summary_user.phone_landline|default('-') }}</dd>
          </div>
          <div>
            <dt>Data de nascimento</dt>
            <dd>{{ summary_user.birth_date|default('-') }}</dd>
          </div>
          <div>
            <dt>Naturalidade</dt>
            <dd>{{ summary_user.birth_place|default('-') }}</dd>
          </div>
        </dl>
      </article>
    {% endif %}
  </section>
{% endblock %}
