{% extends 'layouts/base.twig' %}

{% block head %}
  {% set asset_version = app_asset_version|default('1') %}
  <script src="/assets/js/cedern-hero-carousel.js?v={{ asset_version }}" defer></script>
{% endblock %}

{% block content %}
  <main class="nc-main nc-container nc-home-flow">
    {# Bloco Hero: destaque principal da home com mensagem, midia e controles do carrossel. #}
    {% include 'home/hero.twig' %}

    {# Bloco Social Proof: sinais de confianca/autoridade para reduzir friccao e reforcar credibilidade. #}
    {% include 'home/social-proof.twig' %}

    {# Bloco Testimonials: depoimentos e validacao social para sustentar prova de resultado. #}
    {% include 'home/testimonials.twig' %}

    {# Bloco Quick Access: atalhos estrategicos para as principais rotas da NatalCode. #}
    {% include 'home/quick-access.twig' %}

    {# Bloco Final CTA: chamada de conversao no fechamento da pagina para direcionar o proximo passo. #}
    {% include 'home/final-cta.twig' %}
  </main>
{% endblock %}
