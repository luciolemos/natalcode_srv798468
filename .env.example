# NatalCode UI defaults
# Copie este arquivo para .env quando precisar sobrescrever os padroes locais.
# Valores aceitos:
# APP_DEFAULT_THEME=blue|red|green|violet|amber
# APP_DEFAULT_MODE=light|dark
# APP_DEFAULT_DARK_INTENSITY=neutral|vivid
# APP_DEFAULT_PAGE_TITLE=MeuProjeto | Solucoes web
# APP_DEFAULT_PAGE_DESCRIPTION=Descricao curta para SEO e compartilhamento
# APP_DEFAULT_PAGE_URL=https://seusite.com/
# APP_DEFAULT_PAGE_IMAGE=https://seusite.com/assets/img/social-share.jpg
# APP_DEFAULT_SITE_NAME=Nome institucional exibido em og:site_name
# APP_DEFAULT_TWITTER_SITE=@seuperfil
# A preferencia salva no navegador continua tendo prioridade.

APP_DEFAULT_THEME=amber
APP_DEFAULT_MODE=light
APP_DEFAULT_DARK_INTENSITY=neutral
APP_DEFAULT_PAGE_TITLE="CEDE | Centro de Estudos da Doutrina Espírita"
APP_DEFAULT_PAGE_DESCRIPTION="Centro de Estudos da Doutrina Espírita (CEDE): instituição filantrópica dedicada ao estudo, à prática e à divulgação da Doutrina Espírita."
APP_DEFAULT_PAGE_URL="https://cedern.org/"
APP_DEFAULT_PAGE_IMAGE="https://cedern.org/assets/img/cedern/cede1_1600_1000.png"
APP_DEFAULT_SITE_NAME="CEDE"
APP_DEFAULT_TWITTER_SITE="@cedeoficialrn"
