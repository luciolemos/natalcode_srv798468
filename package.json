{
  "name": "natalcode-visual-tests",
  "private": true,
  "version": "1.0.0",
  "description": "Visual regression tests for NatalCode landing",
  "scripts": {
    "test": "npm run test:visual",
    "test:visual": "env -u NO_COLOR XDEBUG_MODE=off playwright test",
    "test:visual:update": "env -u NO_COLOR XDEBUG_MODE=off playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
